# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma

# test output (screenshots, PDFs, API responses)
scripts/test-output/

# worktrees
.worktrees/
.env*.local

# Claude Code local project config
.claude/

# Local outputs from invoice backfill / diagnostic scripts
backfill-failures.json

# Mobile-audit screenshot artifacts (Playwright)
/tmp-screenshots/
