# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma

# test output (screenshots, PDFs, API responses)
scripts/test-output/
dashboard-*.png

# worktrees
.worktrees/
.env*.local

# Claude Code local project config
.claude/
.codex/

# Local outputs from invoice backfill / diagnostic scripts
backfill-failures.json

# Mobile-audit screenshot artifacts (Playwright)
/tmp-screenshots/

# Performance audit scratch artifacts (Playwright screenshots + perf-audit reports)
/tmp/

# Local Playwright MCP browser snapshots (page YAML + console logs per session)
.playwright-mcp/

# Chat eval harness output (markdown reports per run, kept local)
scripts/eval-chat/runs/

# TrueCourse local artifacts (analyze lock + logs)
.truecourse/

# graphify knowledge graph output
/graphify-out/

# Playwright e2e artifacts
/test-results/
/playwright-report/
/playwright/.cache/

# Python ML pipeline (ml/) local artifacts
__pycache__/
*.pyc
.venv-ml/
ml/.venv/

# local runtime logs
/logs/
