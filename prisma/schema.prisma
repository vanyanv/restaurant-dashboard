generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

enum Role {
  OWNER
  DEVELOPER
}

enum Shift {
  MORNING
  EVENING
  BOTH
}

enum InvoiceStatus {
  PENDING
  MATCHED
  REVIEW
  APPROVED
  REJECTED
}

enum CogsStatus {
  COSTED
  UNMAPPED
  MISSING_COST
}

/// Tenant boundary for the dashboard. Every user, store, invoice, recipe,
/// etc. belongs to exactly one Account. Multiple users can share an account
/// (via the Invite flow) and see the same data. For now there is exactly
/// one Account row in production; the model is in place for future
/// multi-tenancy.
model Account {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users                         User[]
  stores                        Store[]
  invoices                      Invoice[]
  recipes                       Recipe[]
  canonicalIngredients          CanonicalIngredient[]
  ingredientSkuMatches          IngredientSkuMatch[]
  conversations                 Conversation[]
  invoiceLineEmbeddings         InvoiceLineEmbedding[]
  menuItemEmbeddings            MenuItemEmbedding[]
  recipeEmbeddings              RecipeEmbedding[]
  canonicalIngredientEmbeddings CanonicalIngredientEmbedding[]
  pnlNarrativeEmbeddings        PnlNarrativeEmbedding[]
  invites                       Invite[]
  vendorLeadTimes               VendorLeadTime[]
}

/// Single-use, time-limited signup token. An OWNER on an account creates
/// an Invite locally; the invitee opens /signup/{token}, signs up, and is
/// attached to the same accountId. The invite is marked consumed on
/// successful signup. Creation is gated to NODE_ENV !== "production" — the
/// dashboard should not expose invite generation in production. The
/// public consumption route is always live.
model Invite {
  id              String    @id @default(cuid())
  token           String    @unique
  accountId       String
  createdByUserId String
  expiresAt       DateTime
  usedAt          DateTime?
  usedByUserId    String?
  revokedAt       DateTime?
  createdAt       DateTime  @default(now())

  account   Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
  createdBy User    @relation("InvitesCreated", fields: [createdByUserId], references: [id])
  usedBy    User?   @relation("InvitesUsed", fields: [usedByUserId], references: [id])

  @@index([accountId])
  @@index([token])
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      Role
  accountId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Profile
  phone     String?
  avatarUrl String?
  timezone  String  @default("America/New_York")

  // Notification standing orders
  notifyInvoices     Boolean @default(true)
  notifyWeeklyReport Boolean @default(true)
  notifyAnomaly      Boolean @default(true)

  // Relations
  account              Account               @relation(fields: [accountId], references: [id])
  ownedStores          Store[]               @relation("StoreOwner")
  invoices             Invoice[]
  recipes              Recipe[]
  canonicalIngredients CanonicalIngredient[]
  ingredientSkuMatches IngredientSkuMatch[]
  conversations        Conversation[]
  invitesCreated       Invite[]              @relation("InvitesCreated")
  invitesUsed          Invite[]              @relation("InvitesUsed")
  stockCountsCreated   StockCount[]          @relation("StockCountsCreated")
  inventoryAdjustments InventoryAdjustment[] @relation("InventoryAdjustmentsCreated")

  @@index([email])
  @@index([accountId])
}

model Store {
  id        String   @id @default(cuid())
  name      String
  address   String?
  phone     String?
  ownerId   String
  accountId String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Yelp integration fields
  yelpBusinessId  String? // Yelp's unique business ID
  yelpRating      Float? // 1-5 star rating
  yelpReviewCount Int? // Total number of reviews
  yelpUrl         String? // Link to Yelp business page
  yelpUpdatedAt   DateTime? // Last time Yelp data was fetched
  yelpSearchTerm  String? // Store name + address used for search
  yelpLastSearch  DateTime? // Prevent excessive API calls

  // Fixed cost inputs for P&L (monthly figures; converted per period when displayed)
  fixedMonthlyLabor    Float?
  fixedMonthlyRent     Float?
  fixedMonthlyTowels   Float? // Towels/linen service; entered weekly in UI, stored as monthly equivalent
  fixedMonthlyCleaning Float? // Recurring deep-cleaning service

  // Platform commission rates (decimal, e.g. 0.21 = 21%). Applied to tpGrossSales on the P&L.
  uberCommissionRate     Float @default(0.21)
  doordashCommissionRate Float @default(0.25)

  // Per-store COGS target as a percent (e.g. 28.5 for 28.5%). Drives the
  // /dashboard/cogs target band and the "vs target" KPI. Nullable so existing
  // stores remain valid until set via the topbar chip.
  targetCogsPct Float?

  // Optional geocoding used by offline weather / event signal backfills.
  latitude                   Float?
  longitude                  Float?
  geocodedAt                 DateTime?
  geocodeProvider            String?
  geocodeConfidence          Float?
  eventSignalRadiusMiles     Float?
  eventSignalRadiusProvider  String?
  eventSignalRadiusUpdatedAt DateTime?

  // ML lifecycle (Phase 1 W5). Drives nightly job behavior:
  //   pre_open   -> skip training/forecasting; dashboard shows "Opening soon"
  //   warming_up -> emit Hollywood-derived transfer forecasts; train native in parallel
  //   ready      -> native model in production; participates in MinTrace reconciliation
  // pre_open -> warming_up is an ops flip (set when the store physically opens).
  // warming_up -> ready is automatic via ml.lifecycle.should_promote_to_ready.
  lifecycleStage        LifecycleStage @default(pre_open)
  initialTransferScalar Float?
  openedAt              DateTime?

  // Relations
  owner                 User                     @relation("StoreOwner", fields: [ownerId], references: [id])
  account               Account                  @relation(fields: [accountId], references: [id])
  prepTasks             PrepTask[]
  otterStores           OtterStore[]
  otterSummaries        OtterDailySummary[]
  otterHourlySummaries  OtterHourlySummary[]
  otterMenuCategories   OtterMenuCategory[]
  otterMenuItems        OtterMenuItem[]
  otterRatings          OtterRating[]
  invoices              Invoice[]
  ingredientAliases     IngredientAlias[]
  otterItemMappings     OtterItemMapping[]
  otterSubItemMappings  OtterSubItemMapping[]
  otterOrders           OtterOrder[]
  dailyCogsItems        DailyCogsItem[]
  aiForecastRuns        AiForecastRun[]
  jobRuns               JobRun[]
  stockCounts           StockCount[]
  inventoryAdjustments  InventoryAdjustment[]
  modelStates           IngredientModelState[]
  forecastDailyRevenue  ForecastDailyRevenue[]
  forecastHourlyOrders  ForecastHourlyOrders[]
  forecastMenuItems     ForecastMenuItem[]
  mlForecastEvaluations MlForecastEvaluation[]
  forecastDailyCategory ForecastDailyCategory[]
  mlReconciliationDaily MlReconciliationDaily[]
  growthOpportunities   GrowthOpportunity[]
  anomalyEvents         AnomalyEvent[]
  menuItemElasticities  MenuItemElasticity[]
  weatherSignals        StoreWeatherSignal[]
  eventSignals          StoreEventSignal[]
  eventDetailSignals    StoreEventDetailSignal[]
  externalSignalRuns    ExternalSignalSyncRun[]

  // Harri scheduling integration (LiveWire) — labor cost + clock-in alerts
  harriBrands            HarriBrand[]
  harriDailyLabor        HarriDailyLabor[]
  harriPositionDaily     HarriPositionDaily[]
  harriTimekeepingAlerts HarriTimekeepingAlert[]
  harriEmployees         HarriEmployee[]

  @@index([ownerId])
  @@index([accountId])
  @@index([yelpBusinessId])
  @@index([latitude, longitude])
}

model OtterStore {
  id           String    @id @default(cuid())
  storeId      String
  otterStoreId String    @unique
  lastSyncAt   DateTime?
  createdAt    DateTime  @default(now())

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)
}

model OtterDailySummary {
  id            String   @id @default(cuid())
  storeId       String
  date          DateTime @db.Date
  platform      String
  paymentMethod String

  // FP financials (first-party only)
  fpGrossSales     Float?
  fpNetSales       Float?
  fpDiscounts      Float?
  fpFees           Float?
  fpLostRevenue    Float?
  fpTaxCollected   Float?
  fpTaxRemitted    Float?
  fpTips           Float?
  fpServiceCharges Float?
  fpLoyalty        Float?

  // 3P financials (third-party only)
  tpGrossSales         Float?
  tpNetSales           Float?
  tpFees               Float?
  tpTaxCollected       Float?
  tpTaxRemitted        Float?
  tpDiscounts          Float?
  tpRefundsAdjustments Float?
  tpServiceCharges     Float?
  tpTipForRestaurant   Float?
  tpLoyaltyDiscount    Float?

  // Order counts
  fpOrderCount Int?
  tpOrderCount Int?

  // Till (FP cash rows only)
  tillPaidIn  Float?
  tillPaidOut Float?

  syncedAt DateTime @default(now()) @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, date, platform, paymentMethod])
  @@index([storeId])
  @@index([date])
  @@index([storeId, date, platform], map: "OtterDailySummary_store_date_platform_idx")
}

model OtterHourlySummary {
  id         String   @id @default(cuid())
  storeId    String
  date       DateTime @db.Date // LA calendar date
  hour       Int // 0–23, LA local hour
  orderCount Int      @default(0)
  netSales   Float    @default(0)
  updatedAt  DateTime @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, date, hour])
  @@index([date])
  @@index([storeId, date])
}

model OtterMenuCategory {
  id       String   @id @default(cuid())
  storeId  String
  date     DateTime @db.Date
  category String

  fpQuantitySold       Float @default(0)
  fpTotalInclModifiers Float @default(0)
  fpTotalSales         Float @default(0)
  tpQuantitySold       Float @default(0)
  tpTotalInclModifiers Float @default(0)
  tpTotalSales         Float @default(0)

  syncedAt DateTime @default(now()) @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, date, category])
  @@index([storeId, date])
}

model OtterMenuItem {
  id       String   @id @default(cuid())
  storeId  String
  date     DateTime @db.Date
  category String
  itemName String

  isModifier Boolean @default(false)

  fpQuantitySold       Float @default(0)
  fpTotalInclModifiers Float @default(0)
  fpTotalSales         Float @default(0)
  tpQuantitySold       Float @default(0)
  tpTotalInclModifiers Float @default(0)
  tpTotalSales         Float @default(0)

  syncedAt DateTime @default(now()) @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, date, category, itemName, isModifier])
  @@index([storeId, date])
  @@index([storeId, isModifier, date, itemName], map: "OtterMenuItem_store_modifier_date_item_idx")
}

model OtterRating {
  id               String   @id @default(cuid())
  storeId          String
  externalReviewId String
  brandName        String
  facilityName     String
  storeName        String
  reviewedAt       DateTime
  platform         String
  reviewText       String?
  rating           Int
  externalOrderId  String?
  orderItemNames   String?
  syncedAt         DateTime @default(now()) @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, externalReviewId])
  @@index([storeId])
  @@index([reviewedAt])
  @@index([platform])
}

model PrepTask {
  id          String   @id @default(cuid())
  storeId     String
  taskName    String
  description String?
  shift       Shift
  isActive    Boolean  @default(true)
  orderIndex  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId])
}

model Invoice {
  id        String  @id @default(cuid())
  ownerId   String
  accountId String
  storeId   String?

  // Source tracking
  emailMessageId  String    @unique
  emailSubject    String?
  emailReceivedAt DateTime?
  attachmentName  String?

  // Extracted header
  vendorName      String
  invoiceNumber   String
  invoiceDate     DateTime? @db.Date
  dueDate         DateTime? @db.Date
  deliveryAddress String?

  // Totals
  subtotal    Float?
  taxAmount   Float?
  totalAmount Float

  // True for returns / credit memos. totalAmount, subtotal, taxAmount, and
  // line-item extendedPrice/quantity are all stored with their natural
  // negative sign so SUM() yields net spend without special-casing.
  isReturn Boolean @default(false)

  // Matching
  status          InvoiceStatus @default(PENDING)
  matchConfidence Float?
  matchedAt       DateTime?

  // Gemini extraction metadata
  rawExtractionJson String?
  extractionModel   String?

  // PDF storage (private Cloudflare R2 object key + metadata)
  pdfBlobPathname String?
  pdfBlobUrl      String?
  pdfSize         Int?
  pdfUploadedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  owner     User              @relation(fields: [ownerId], references: [id])
  account   Account           @relation(fields: [accountId], references: [id])
  store     Store?            @relation(fields: [storeId], references: [id], onDelete: SetNull)
  lineItems InvoiceLineItem[]

  @@index([ownerId])
  @@index([accountId])
  @@index([storeId])
  @@index([vendorName])
  @@index([invoiceDate])
  @@index([status])
  @@index([ownerId, createdAt])
  @@index([accountId, createdAt])
  @@index([ownerId, vendorName, invoiceDate])
  @@index([accountId, vendorName, invoiceDate])
  @@index([accountId, isReturn])
  @@index([accountId, dueDate, isReturn], map: "Invoice_account_dueDate_return_idx")
  @@index([accountId, storeId, dueDate, isReturn], map: "Invoice_account_store_dueDate_return_idx")
  @@index([accountId, invoiceDate, isReturn], map: "Invoice_account_invoiceDate_return_idx")
}

model InvoiceLineItem {
  id            String  @id @default(cuid())
  invoiceId     String
  lineNumber    Int
  sku           String?
  productName   String
  description   String?
  category      String?
  quantity      Float
  unit          String?
  packSize      Int?
  unitSize      Float?
  unitSizeUom   String?
  unitPrice     Float
  extendedPrice Float

  // Ingredient unification. Populated at sync time via (vendor, sku) match,
  // or at review-queue time by a manual confirm. Null = unmatched.
  canonicalIngredientId String?
  matchSource           String? // "sku" | "manual" | "alias"
  matchedAt             DateTime?

  invoice             Invoice              @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  canonicalIngredient CanonicalIngredient? @relation(fields: [canonicalIngredientId], references: [id], onDelete: SetNull)

  @@index([invoiceId])
  @@index([category])
  @@index([sku])
  @@index([canonicalIngredientId])
}

model InvoiceSyncLog {
  id              String    @id @default(cuid())
  startedAt       DateTime  @default(now())
  completedAt     DateTime?
  emailsScanned   Int       @default(0)
  invoicesCreated Int       @default(0)
  invoicesSkipped Int       @default(0)
  errors          Int       @default(0)
  errorDetails    String?
  triggeredBy     String
}

model Recipe {
  id               String   @id @default(cuid())
  ownerId          String
  accountId        String
  itemName         String
  category         String
  /// Portions yielded per recipe. Must be > 0 (DB CHECK constraint
  /// `recipe_serving_size_positive` in the manual migration).
  servingSize      Float    @default(1)
  notes            String?
  foodCostOverride Float?
  isSellable       Boolean  @default(true)
  isAiGenerated    Boolean  @default(false)
  isConfirmed      Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  owner                User                  @relation(fields: [ownerId], references: [id])
  account              Account               @relation(fields: [accountId], references: [id])
  ingredients          RecipeIngredient[]
  usedInIngredients    RecipeIngredient[]    @relation("ComponentRecipe")
  otterItemMappings    OtterItemMapping[]
  otterSubItemMappings OtterSubItemMapping[]
  dailyCogsItems       DailyCogsItem[]

  @@unique([ownerId, itemName, category])
  @@unique([accountId, itemName, category])
  @@index([ownerId])
  @@index([accountId])
}

/// A line in a recipe. Exactly one of `canonicalIngredientId` or `componentRecipeId`
/// must be set; this is enforced by a DB CHECK constraint in the migration.
model RecipeIngredient {
  id                    String   @id @default(cuid())
  recipeId              String
  canonicalIngredientId String?
  componentRecipeId     String?
  ingredientName        String?
  quantity              Float
  unit                  String
  notes                 String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  recipe              Recipe               @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  canonicalIngredient CanonicalIngredient? @relation(fields: [canonicalIngredientId], references: [id], onDelete: Restrict)
  componentRecipe     Recipe?              @relation("ComponentRecipe", fields: [componentRecipeId], references: [id], onDelete: Restrict)

  @@index([recipeId])
  @@index([canonicalIngredientId])
  @@index([componentRecipeId])
}

model CanonicalIngredient {
  id          String   @id @default(cuid())
  ownerId     String
  accountId   String
  name        String
  defaultUnit String
  category    String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  /// How this ingredient is measured in recipes (lb, oz, each, tbsp, cup, gal, fl oz, g, ml, l).
  /// Null until set manually or hydrated from an invoice match.
  recipeUnit        String?
  /// Dollars per recipeUnit. Null when unknown.
  costPerRecipeUnit Float?
  /// "manual" — user-entered; "invoice" — auto-derived from latest matched line item.
  costSource        String?
  /// When true, invoice-match recomputes won't overwrite a manually set cost.
  costLocked        Boolean   @default(false)
  costUpdatedAt     DateTime?

  /// Product reference photo stored in R2 under `products/{id}-{uuid}.{ext}`.
  /// Set by the DEVELOPER-only mobile admin uploader; served through an
  /// authenticated API route (no public URL). One photo per ingredient.
  photoBlobPathname String?
  photoContentType  String?
  photoUploadedAt   DateTime?

  /// Pack definition for three-tier mobile stock counting.
  /// `caseUnit` + `recipeUnitsPerCase` define tier 1 (case-level). Both null
  /// hides the case tier and the count card falls back to canonical-only.
  /// `innerPackUnit` + `innerPacksPerCase` define tier 2 (inner-pack); both
  /// null hides that tier (e.g. catch-weight meat has no inner pack).
  caseUnit           String?
  innerPackUnit      String?
  recipeUnitsPerCase Float?
  innerPacksPerCase  Float?

  owner                User                   @relation(fields: [ownerId], references: [id])
  account              Account                @relation(fields: [accountId], references: [id])
  aliases              IngredientAlias[]
  recipeIngredients    RecipeIngredient[]
  invoiceLineItems     InvoiceLineItem[]
  skuMatches           IngredientSkuMatch[]
  stockCountLines      StockCountLine[]
  inventoryAdjustments InventoryAdjustment[]
  modelStates          IngredientModelState[]

  @@unique([ownerId, name])
  @@unique([accountId, name])
  @@index([ownerId])
  @@index([accountId])
}

/// Learned (vendor, sku) → canonical ingredient matches. Future invoice line
/// items with the same (vendor, sku) auto-link to the canonical at sync time.
/// Manual matches from the review queue upsert here and backfill history.
model IngredientSkuMatch {
  id                    String   @id @default(cuid())
  ownerId               String
  accountId             String
  vendorName            String
  sku                   String
  canonicalIngredientId String
  conversionFactor      Float    @default(1)
  fromUnit              String
  toUnit                String
  confirmedBy           String
  confirmedAt           DateTime @default(now())

  owner               User                @relation(fields: [ownerId], references: [id])
  account             Account             @relation(fields: [accountId], references: [id])
  canonicalIngredient CanonicalIngredient @relation(fields: [canonicalIngredientId], references: [id], onDelete: Cascade)

  @@unique([ownerId, vendorName, sku])
  @@unique([accountId, vendorName, sku])
  @@index([canonicalIngredientId])
  @@index([ownerId])
  @@index([accountId])
}

model IngredientAlias {
  id                    String   @id @default(cuid())
  storeId               String
  canonicalIngredientId String?
  canonicalName         String
  rawName               String
  conversionFactor      Float    @default(1)
  fromUnit              String
  toUnit                String
  createdAt             DateTime @default(now())

  store               Store                @relation(fields: [storeId], references: [id], onDelete: Cascade)
  canonicalIngredient CanonicalIngredient? @relation(fields: [canonicalIngredientId], references: [id], onDelete: SetNull)

  @@unique([storeId, rawName])
  @@index([storeId, canonicalName])
  @@index([canonicalIngredientId])
}

model OtterItemMapping {
  id            String   @id @default(cuid())
  storeId       String
  otterItemName String
  /// Stable Otter sku (preferred for modern mappings). Legacy rows may leave this null.
  skuId         String?
  recipeId      String
  confirmedAt   DateTime @default(now())
  createdAt     DateTime @default(now())

  store  Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)
  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@unique([storeId, otterItemName])
  @@index([storeId])
  @@index([recipeId])
  @@index([skuId])
}

/// Per-(store, sub-item SKU) mapping of an Otter order modifier → a Recipe
/// that represents the modifier's ingredient usage (e.g. "Mod: Add Lettuce" →
/// 1 leaf). Multiple Otter sub-item SKUs with the same meaning (e.g.
/// "Add Pickle" vs "Add Pickles" with distinct Otter SKUs) can share one
/// recipe. Drives modifier cost in the daily COGS walker.
model OtterSubItemMapping {
  id               String   @id @default(cuid())
  storeId          String
  /// Stable Otter sub-item SKU — our primary key. Every OtterOrderSubItem has one.
  skuId            String
  /// Last seen display name for this SKU (for UI). Not used as identity.
  otterSubItemName String
  recipeId         String
  confirmedAt      DateTime @default(now())
  createdAt        DateTime @default(now())

  store  Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)
  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@unique([storeId, skuId])
  @@index([storeId])
  @@index([recipeId])
}

/// Per-(store, date, itemName) COGS row, materialized by
/// `src/lib/cogs-materializer.ts` so P&L reads don't walk recipes / invoices
/// at request time. Materialization is idempotent (upsert + per-day diff
/// cleanup) and runs on its own cron schedule independent of any sync or
/// mutation path. Rows only exist when we can actually cost the item as-of
/// `date`; UNMAPPED items and pre-cost-data dates are not materialized.
model DailyCogsItem {
  id           String     @id @default(cuid())
  storeId      String
  date         DateTime   @db.Date
  itemName     String
  category     String
  recipeId     String?
  qtySold      Float
  salesRevenue Float
  unitCost     Float?
  lineCost     Float      @default(0)
  status       CogsStatus
  /**
   * True when the recipe cost walk flagged at least one line as uncosted
   * (missing canonical cost or unit-conversion failure). `status` can still
   * be COSTED if other lines costed fine — `partialCost` says the total is
   * an understatement.
   */
  partialCost  Boolean    @default(false)
  /**
   * Provenance of `unitCost`. One of:
   * "invoice" — every contributing ingredient was priced from invoice data.
   * "manual"  — every contributing ingredient was priced from a manual cost.
   * "mixed"   — both invoice and manual prices contributed.
   * "override" — the recipe-level `foodCostOverride` was applied (no
   * ingredient walk produced a number).
   * Null for UNMAPPED rows and packaging rows pre-dating this column.
   * Lets dashboards distinguish "this is real $" from "this is a guess."
   */
  costSource   String?
  computedAt   DateTime   @default(now())

  store  Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)
  recipe Recipe? @relation(fields: [recipeId], references: [id], onDelete: SetNull)

  @@unique([storeId, date, itemName, category])
  @@index([storeId, date])
  @@index([recipeId, date])
}

model OtterOrder {
  id                 String    @id @default(cuid())
  otterOrderId       String    @unique
  externalDisplayId  String?
  storeId            String
  otterStoreId       String
  platform           String
  referenceTimeLocal DateTime
  fulfillmentMode    String?
  orderStatus        String?
  acceptanceStatus   String?
  subtotal           Float     @default(0)
  tax                Float     @default(0)
  tip                Float     @default(0)
  commission         Float     @default(0)
  discount           Float     @default(0)
  total              Float     @default(0)
  customerName       String?
  detailsFetchedAt   DateTime?
  syncedAt           DateTime  @default(now()) @updatedAt

  store Store            @relation(fields: [storeId], references: [id], onDelete: Cascade)
  items OtterOrderItem[]

  @@index([storeId, referenceTimeLocal])
  // The drain + monitoring queries filter `detailsFetchedAt IS NULL` against
  // a small subset of the table; that's served by a partial index (Prisma
  // can't express partial). See:
  //   prisma/manual-migrations/2026-05-03_otter_pending_details_index.sql
  // — index name `OtterOrder_pending_details_idx`.
  @@index([platform])
}

model OtterOrderItem {
  id       String @id @default(cuid())
  orderId  String
  skuId    String
  name     String
  quantity Float
  price    Float  @default(0)

  order    OtterOrder          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  subItems OtterOrderSubItem[]

  @@index([orderId])
  @@index([skuId])
}

model OtterOrderSubItem {
  id          String  @id @default(cuid())
  orderItemId String
  skuId       String
  name        String
  quantity    Float
  price       Float   @default(0)
  subHeader   String?

  orderItem OtterOrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  @@index([orderItemId])
  @@index([skuId])
}

/// One row per AI demand/sales prediction. After the target window closes,
/// the daily reconciliation job writes back `actualValue` and `errorPct` so
/// the next forecast run can self-calibrate per (storeId, target).
///
/// `storeId` is required — forecasts are always store-scoped (ingredient
/// usage patterns differ across kitchens).
model AiForecastRun {
  id                String    @id @default(cuid())
  storeId           String
  /// Stable identifier for the thing being predicted (e.g. canonical
  /// ingredient name, menu item slug). The next-run prompt uses this to
  /// look up the most recent residual.
  target            String
  /// Predicted quantity for the target window, in `unit`.
  predictedValue    Float
  unit              String
  confidence        String? // "high" | "medium" | "low"
  /// Inclusive start / exclusive end of the window the prediction covers.
  targetWindowStart DateTime
  targetWindowEnd   DateTime
  /// Set by the reconciliation job after `targetWindowEnd` passes.
  actualValue       Float?
  errorPct          Float?
  reconciledAt      DateTime?
  generatedAt       DateTime  @default(now())

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId, target, generatedAt])
  @@index([targetWindowEnd, reconciledAt])
}

/// Owner-scoped chat thread. Each conversation is a sequence of `Message`
/// rows; the drawer and `/dashboard/chat` page share the same store so a
/// thread is portable across the two surfaces.
model Conversation {
  id        String    @id @default(cuid())
  ownerId   String
  accountId String
  owner     User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  account   Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  /// LLM-generated short title written after the first assistant turn. Null
  /// until then; the rail falls back to "Untitled".
  title     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  messages  Message[]

  @@index([ownerId, updatedAt])
  @@index([accountId, updatedAt])
}

/// One turn in a conversation. `role` is "user" | "assistant" | "tool".
/// Assistant turns may have one or more `ToolCall` children captured
/// alongside the streamed reply for the tool-trace expander.
model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String
  content        String
  toolCalls      ToolCall[]
  createdAt      DateTime     @default(now())

  @@index([conversationId, createdAt])
}

/// One tool invocation by the LLM during an assistant turn. `args` and
/// `result` are stored verbatim for the trace UI; `durationMs` is wall-clock
/// time of `execute()`.
model ToolCall {
  id         String   @id @default(cuid())
  messageId  String
  message    Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  toolName   String
  args       Json
  result     Json
  durationMs Int
  createdAt  DateTime @default(now())

  @@index([messageId])
}

/// pgvector embedding for one invoice line (or whole-invoice header when
/// `invoiceLineId` is null). `ownerId` is denormalized for fast `WHERE`
/// filtering during similarity search; we never trust the client.
/// `contentSnapshot` is the exact text that was embedded — used to skip
/// re-embedding unchanged rows.
model InvoiceLineEmbedding {
  id              String                      @id @default(cuid())
  invoiceId       String
  invoiceLineId   String?
  ownerId         String
  accountId       String
  contentSnapshot String
  embedding       Unsupported("vector(1536)")
  createdAt       DateTime                    @default(now())

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([ownerId])
  @@index([accountId])
  @@index([invoiceId])
}

/// pgvector embedding for one distinct Otter menu item (per
/// store + category + itemName tuple, modifiers excluded). The embedding
/// itself is keyed by a synthetic `menuItemId` (sha256 of the tuple,
/// truncated) so re-embeds overwrite prior rows. The tuple fields are
/// denormalized so `searchMenuItems` can return ready-to-display rows
/// without joining back to OtterMenuItem.
model MenuItemEmbedding {
  id              String                      @id @default(cuid())
  menuItemId      String                      @unique
  ownerId         String
  accountId       String
  storeId         String
  category        String
  itemName        String
  contentSnapshot String
  embedding       Unsupported("vector(1536)")
  createdAt       DateTime                    @default(now())

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([ownerId])
  @@index([accountId])
  @@index([storeId])
}

/// pgvector embedding for one owner-built Recipe. Chunk text folds in the
/// recipe's first few RecipeIngredient names so a query like "cheese
/// burger" can hit a recipe whose ingredients include cheddar even when
/// the recipe is just named "Smash Burger". `category` is denormalized so
/// `searchRecipes` can return ready-to-display rows without joining back.
model RecipeEmbedding {
  id              String                      @id @default(cuid())
  recipeId        String                      @unique
  ownerId         String
  accountId       String
  category        String
  itemName        String
  contentSnapshot String
  embedding       Unsupported("vector(1536)")
  createdAt       DateTime                    @default(now())

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([ownerId])
  @@index([accountId])
}

/// pgvector embedding for one owner CanonicalIngredient. Chunk text folds
/// in the per-store IngredientAlias `rawName`s so vendor jargon ("16/20
/// EZ peel", "EVOO") matches the canonical. `category` is denormalized so
/// `searchCanonicalIngredients` can return ready-to-display rows without
/// joining back.
model CanonicalIngredientEmbedding {
  id                    String                      @id @default(cuid())
  canonicalIngredientId String                      @unique
  ownerId               String
  accountId             String
  category              String?
  name                  String
  contentSnapshot       String
  embedding             Unsupported("vector(1536)")
  createdAt             DateTime                    @default(now())

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([ownerId])
  @@index([accountId])
}

/// pgvector embedding for one weekly P&L narrative snapshot — one per
/// (account, store|null, weekStart). storeId=null is the all-stores rollup
/// for the account. `snapshotId` is sha256 of the (account, store|all,
/// weekStart) tuple so re-embeds upsert. Used by `searchPnlHistory` for
/// historical narrative questions ("when was COGS last this high?"). Live
/// numerics for the current week come from `getPnlSummary`, never from here.
model PnlNarrativeEmbedding {
  id              String                      @id @default(cuid())
  snapshotId      String                      @unique
  accountId       String
  storeId         String?
  weekStart       DateTime                    @db.Date
  contentSnapshot String
  embedding       Unsupported("vector(1536)")
  createdAt       DateTime                    @default(now())

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@index([storeId])
  @@index([weekStart])
}

// ─────────────────────────────────────────────────────────────────────────
// Monitoring (dev-only) — see docs/superpowers/specs/2026-04-30-dev-monitoring-design.md
// ─────────────────────────────────────────────────────────────────────────

enum JobStatus {
  RUNNING
  SUCCESS
  FAILURE
  PARTIAL
}

model JobRun {
  id           String    @id @default(cuid())
  jobName      String
  storeId      String?
  triggeredBy  String
  startedAt    DateTime  @default(now())
  completedAt  DateTime?
  durationMs   Int?
  status       JobStatus @default(RUNNING)
  rowsWritten  Int?
  metadata     Json?
  errorMessage String?
  errorStack   String?

  store Store? @relation(fields: [storeId], references: [id], onDelete: SetNull)

  @@index([jobName, startedAt(sort: Desc)])
  // Compound — supports getSyncsByStore (`findFirst where { jobName, storeId } orderBy startedAt DESC`).
  @@index([jobName, storeId, startedAt(sort: Desc)])
  @@index([status, startedAt(sort: Desc)])
}

model AiUsageEvent {
  id               String   @id @default(cuid())
  occurredAt       DateTime @default(now())
  feature          String
  provider         String
  model            String
  inputTokens      Int
  outputTokens     Int
  cachedTokens     Int      @default(0)
  estimatedCostUsd Decimal  @db.Decimal(10, 6)
  storeId          String?
  userId           String?
  durationMs       Int?

  chatTurns ChatTurn[]

  @@index([occurredAt(sort: Desc)])
  @@index([feature, occurredAt(sort: Desc)])
}

model ErrorEvent {
  id         String   @id @default(cuid())
  occurredAt DateTime @default(now())
  source     String
  route      String?
  method     String?
  status     Int?
  message    String
  stack      String?
  userId     String?
  storeId    String?
  metadata   Json?

  @@index([occurredAt(sort: Desc)])
  @@index([source, occurredAt(sort: Desc)])
}

model ChatTurn {
  id               String        @id @default(cuid())
  conversationId   String
  occurredAt       DateTime      @default(now())
  userId           String?
  storeId          String?
  userMessage      String        @db.Text
  assistantMessage String?       @db.Text
  toolsUsed        String[]
  aiUsageEventId   String?
  aiUsageEvent     AiUsageEvent? @relation(fields: [aiUsageEventId], references: [id], onDelete: SetNull)
  status           String        @default("OK")
  finishReason     String?
  errorMessage     String?
  toolErrors       Json?
  feedback         String?

  @@index([occurredAt(sort: Desc)])
  @@index([conversationId, occurredAt])
}

model CacheStat {
  id         String   @id @default(cuid())
  hourBucket DateTime
  keyPrefix  String
  hits       Int      @default(0)
  misses     Int      @default(0)
  writes     Int      @default(0)
  busts      Int      @default(0)
  failures   Int      @default(0)

  @@unique([hourBucket, keyPrefix])
  @@index([hourBucket(sort: Desc)])
}

model DbSnapshot {
  id         String   @id @default(cuid())
  capturedAt DateTime @default(now())
  date       DateTime @unique @db.Date
  totalBytes BigInt
  perTable   Json

  @@index([date(sort: Desc)])
}

/// Periodic snapshot of Vercel plan quotas, polled every ~15 min from
/// `GET /v1/usage` with `VERCEL_TOKEN`. `metrics` carries all 10 Hobby-plan
/// gauges (blob ops, fluid CPU, function invocations, edge requests, ISR
/// reads, image optimization, fast origin transfer, blob storage,
/// provisioned memory, blob simple ops) as `{ used, limit }` pairs.
model VercelUsageSnapshot {
  id           String   @id @default(cuid())
  capturedAt   DateTime @default(now())
  billingCycle String
  metrics      Json

  @@index([capturedAt(sort: Desc)])
  @@index([billingCycle])
}

enum LoginKind {
  SIGN_IN
  SIGN_OUT
  SIGN_IN_FAILED
}

/// Login audit trail. `userId` null on failed attempts (we still capture
/// the email tried). `SIGN_OUT` is recorded best-effort from the NextAuth
/// `events.signOut` callback. Live presence is derived from this stream:
/// users with a recent `SIGN_IN` and no later `SIGN_OUT` within JWT TTL
/// are considered online (we use JWT strategy, so there is no Session
/// table to enumerate).
model LoginEvent {
  id         String    @id @default(cuid())
  userId     String?
  emailTried String
  kind       LoginKind
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime  @default(now())

  @@index([userId, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
}

/// Daily R2 bucket size snapshot, written by the
/// `/api/cron/r2-snapshot` route via `ListObjectsV2` against the configured
/// R2 bucket. `byPrefix` rolls up `{ bytes, count }` per top-level prefix
/// (e.g. `invoices/`) so the infrastructure drilldown can show what's
/// taking space without re-listing.
model R2BucketSnapshot {
  id          String   @id @default(cuid())
  capturedAt  DateTime @default(now())
  totalBytes  BigInt
  objectCount Int
  byPrefix    Json

  @@index([capturedAt(sort: Desc)])
}

// =============================================================================
// Inventory: stock counts, adjustments, vendor lead-time cache
// (Phase 1 of the inventory + reorder + waste roadmap — see docs/backlog-mapping.md)
// =============================================================================

enum StockCountStatus {
  IN_PROGRESS
  COMPLETED
  ABANDONED
}

/// Header row for one physical inventory count at one store. Operators do an
/// opening count, then weekly recounts. `completedAt` is set when the count
/// is finalized; that's when waste-delta and calibration jobs run against it.
model StockCount {
  id              String           @id @default(cuid())
  storeId         String
  countedByUserId String
  status          StockCountStatus @default(IN_PROGRESS)
  startedAt       DateTime         @default(now())
  countedAt       DateTime
  completedAt     DateTime?
  note            String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  store         Store            @relation(fields: [storeId], references: [id], onDelete: Cascade)
  countedByUser User             @relation("StockCountsCreated", fields: [countedByUserId], references: [id])
  lines         StockCountLine[]

  @@index([storeId, countedAt(sort: Desc)])
  @@index([storeId, status])
  @@index([countedByUserId])
}

/// One ingredient line within a count. `qtyInRecipeUnit` is the canonical
/// value used by every downstream calc (running on-hand, waste delta,
/// calibration). `nativeQty`/`nativeUnit` capture how the operator counted
/// (e.g. "2 cases") for UX + audit, with the conversion applied via
/// IngredientSkuMatch.conversionFactor at save time.
///
/// `estimatedQtyAtCount` and `calibrationFactorAtCount` freeze the model's
/// prediction at the moment of counting — Phase 4 replays these to learn
/// systematic bias without leaking future-knowledge into the training set.
model StockCountLine {
  id                       String   @id @default(cuid())
  stockCountId             String
  canonicalIngredientId    String
  qtyInRecipeUnit          Float
  nativeQty                Float?
  nativeUnit               String?
  note                     String?
  estimatedQtyAtCount      Float?
  calibrationFactorAtCount Float?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  stockCount          StockCount          @relation(fields: [stockCountId], references: [id], onDelete: Cascade)
  canonicalIngredient CanonicalIngredient @relation(fields: [canonicalIngredientId], references: [id], onDelete: Restrict)

  @@unique([stockCountId, canonicalIngredientId])
  @@index([canonicalIngredientId])
}

enum InventoryAdjustmentReason {
  THEFT
  EXPIRY
  SUPPLIER_RETURN
  DAMAGE
  OTHER
}

/// Manual adjustment to running on-hand. Logged for major events only —
/// theft, expiry, supplier returns, damage. Daily spills/comps are absorbed
/// into the weekly recount delta.
model InventoryAdjustment {
  id                    String                    @id @default(cuid())
  storeId               String
  canonicalIngredientId String
  occurredAt            DateTime
  qty                   Float // positive = removed from stock; we always subtract
  reason                InventoryAdjustmentReason
  note                  String?
  createdByUserId       String
  createdAt             DateTime                  @default(now())

  store               Store               @relation(fields: [storeId], references: [id], onDelete: Cascade)
  canonicalIngredient CanonicalIngredient @relation(fields: [canonicalIngredientId], references: [id], onDelete: Restrict)
  createdByUser       User                @relation("InventoryAdjustmentsCreated", fields: [createdByUserId], references: [id])

  @@index([storeId, canonicalIngredientId, occurredAt(sort: Desc)])
  @@index([storeId, occurredAt(sort: Desc)])
  @@index([createdByUserId])
}

/// Cache of auto-derived vendor lead times. Recomputed nightly from
/// Invoice.invoiceDate gaps per (accountId, vendorNameNormalized).
/// `medianLeadDays` falls back to a per-account default when sampleSize < 3.
model VendorLeadTime {
  id                   String   @id @default(cuid())
  accountId            String
  vendorNameNormalized String
  medianLeadDays       Float
  sampleSize           Int
  lastComputedAt       DateTime @default(now())

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, vendorNameNormalized])
  @@index([accountId])
}

enum IngredientConfidenceLevel {
  LOW
  MEDIUM
  HIGH
  VERIFIED
}

/// Per (storeId, canonicalIngredientId) Bayesian calibration state. Each
/// completed StockCount updates `calibrationFactor` (multiplier on theoretical
/// recipe-walk depletion) via an EWMA Bayesian update, and rolls residual
/// statistics (`recountDeltaMean` / `recountDeltaStd`) used for graduation +
/// anomaly scoring. `isGraduated=true` exempts the ingredient from the
/// mandatory weekly count list; the operator only re-counts on spot-checks
/// or when an upstream change (recipe edit, new vendor SKU, menu add) forces
/// re-validation.
model IngredientModelState {
  id                      String                    @id @default(cuid())
  storeId                 String
  canonicalIngredientId   String
  calibrationFactor       Float                     @default(1.0)
  recountDeltaMean        Float                     @default(0)
  recountDeltaM2          Float                     @default(0) // Welford running sum-of-squares
  sampleSize              Int                       @default(0)
  consecutiveTightWeeks   Int                       @default(0)
  isGraduated             Boolean                   @default(false)
  graduatedAt             DateTime?
  lastSpotCheckAt         DateTime?
  confidenceLevel         IngredientConfidenceLevel @default(LOW)
  typicalWeeklyThroughput Float?
  lastUpdatedAt           DateTime                  @default(now())

  store               Store               @relation(fields: [storeId], references: [id], onDelete: Cascade)
  canonicalIngredient CanonicalIngredient @relation(fields: [canonicalIngredientId], references: [id], onDelete: Cascade)

  @@unique([storeId, canonicalIngredientId])
  @@index([storeId, isGraduated])
}

// ---------------------------------------------------------------------------
// ML forecasting layer (Phase 5)
//
// Forecasts are produced by a nightly Python pipeline (ml/run_nightly.py)
// running on GitHub Actions. The pipeline writes precomputed predictions
// here; the Next.js dashboard ONLY reads. Never train inside Vercel.
// ---------------------------------------------------------------------------

enum MlTrainingStatus {
  RUNNING
  SUCCEEDED
  FAILED
}

enum MlTarget {
  REVENUE
  MENU_ITEM
  INVENTORY
  BUSY_HOURS
}

/// Phase 1 W5: store lifecycle progression. See `Store.lifecycleStage`.
/// Transitions: pre_open -> warming_up (ops flip) -> ready (auto via
/// ml.lifecycle.should_promote_to_ready when native beats transfer-forecast
/// WAPE by >=5% with sampleSize >= 60).
enum LifecycleStage {
  pre_open
  warming_up
  ready
}

/// Phase 1 W5: where a forecast row came from. `transfer` rows are emitted
/// by ml/transfer/hollywood_prior.py for warming_up stores; `native` rows
/// are emitted by the per-store XGBoost models. Reconciliation status is
/// signaled separately by `reconciledAt`.
enum ForecastSource {
  native
  transfer
}

/// W9 opportunity types — locked at 5 for Phase 1. The 3 deferred values
/// (launch_analogue, lost_sales, weak_promo) extend additively in Phase 2.
enum OpportunityType {
  reprice
  menu_engineering
  channel_mix
  food_cost_risk
  profit_risk
}

enum OpportunityConfidence {
  low
  medium
  high
}

enum AnomalyMethod {
  ZSCORE
  ISOLATION_FOREST
}

enum AnomalyTarget {
  REVENUE
  MENU_ITEM
  INGREDIENT
  LABOR
  REFUNDS
}

enum AnomalyStatus {
  OPEN
  ACKNOWLEDGED
  EXPLAINED
}

/// One row per nightly pipeline invocation per (target, modelType). Captures
/// MAPE / MAE on a held-out period so the dashboard can tell the operator
/// "revenue forecast accurate within 8% over the last 30 days".
model MlTrainingRun {
  id           String           @id @default(cuid())
  startedAt    DateTime         @default(now())
  completedAt  DateTime?
  modelType    String // "xgboost" | "lightgbm" | "prophet"
  target       MlTarget
  scope        String? // optional store id or "global"
  mape         Float?
  mae          Float?
  sampleSize   Int?
  modelVersion String? // e.g. git sha + timestamp
  artifactPath String? // bucket key when we move artifacts off the runner
  status       MlTrainingStatus @default(RUNNING)
  errorMessage String?

  @@index([target, startedAt(sort: Desc)])
  @@index([status, startedAt(sort: Desc)])
}

/// Daily revenue forecast per store. The Python pipeline writes one row per
/// (storeId, forecastDate) per generation. Newer rows supersede older ones —
/// the dashboard reads the latest by `generatedAt`.
model ForecastDailyRevenue {
  id                   String         @id @default(cuid())
  storeId              String
  forecastDate         DateTime       @db.Date
  /// 0 means whole-day; 1-23 means a specific hour bucket (when we add it).
  hourBucket           Int            @default(0)
  predictedRevenue     Float
  /// 10th / 90th percentile of the predictive interval.
  p10                  Float?
  p90                  Float?
  modelVersion         String
  generatedAt          DateTime       @default(now())
  /// Backfilled by reconciliation when the day closes.
  actualRevenue        Float?
  errorPct             Float?
  reconciledAt         DateTime?
  /// Phase 1 W5: 'native' for per-store XGBoost rows; 'transfer' for
  /// Hollywood-prior rows emitted while the store is warming_up.
  forecastSource       ForecastSource @default(native)
  /// Phase 1 W6-8: reconciled point + interval from MinTrace. Null until the
  /// nightly reconciliation pass writes them. Read helpers fall back to raw
  /// values when null or stale (>48h). See ml/reconciliation/reconcile.py.
  reconciledRevenue    Float?
  reconciledP10        Float?
  reconciledP90        Float?
  reconciliationMethod String?

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, forecastDate, hourBucket, generatedAt])
  @@index([storeId, forecastDate])
  @@index([storeId, forecastDate, hourBucket, generatedAt(sort: Desc)], map: "ForecastDailyRevenue_store_date_hour_generated_idx")
  @@index([generatedAt(sort: Desc)])
  @@index([storeId, forecastSource])
}

/// Hourly order-demand forecast per store. Written by the nightly Python
/// pipeline after training on Otter hourly order history plus bounded Harri
/// labor context. Dashboard request paths read these precomputed rows only.
model ForecastHourlyOrders {
  id              String         @id @default(cuid())
  storeId         String
  forecastDate    DateTime       @db.Date
  hourBucket      Int
  predictedOrders Float
  p10             Float?
  p90             Float?
  modelVersion    String
  generatedAt     DateTime       @default(now())
  actualOrders    Float?
  errorPct        Float?
  reconciledAt    DateTime?
  forecastSource  ForecastSource @default(native)

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, forecastDate, hourBucket, generatedAt])
  @@index([storeId, forecastDate])
  @@index([storeId, forecastDate, hourBucket, generatedAt(sort: Desc)], map: "ForecastHourlyOrders_store_date_hour_generated_idx")
  @@index([generatedAt(sort: Desc)])
  @@index([storeId, forecastSource])
}

/// Daily menu-item demand forecast per store. Joined by `otterItemSkuId`,
/// which matches `OtterOrderItem.skuId` (the stable identifier used by sales
/// history).
model ForecastMenuItem {
  id                   String         @id @default(cuid())
  storeId              String
  otterItemSkuId       String
  forecastDate         DateTime       @db.Date
  predictedQty         Float
  p10                  Float?
  p90                  Float?
  modelVersion         String
  generatedAt          DateTime       @default(now())
  actualQty            Float?
  errorPct             Float?
  reconciledAt         DateTime?
  forecastSource       ForecastSource @default(native)
  /// Phase 1 W6-8: reconciled qty from MinTrace (after dividing reconciled
  /// revenue at this item by the per-item avg price).
  reconciledQty        Float?
  reconciliationMethod String?

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, otterItemSkuId, forecastDate, generatedAt])
  @@index([storeId, forecastDate])
  @@index([storeId, forecastDate, otterItemSkuId, generatedAt(sort: Desc)], map: "ForecastMenuItem_store_date_sku_generated_idx")
  @@index([generatedAt(sort: Desc)])
  @@index([storeId, forecastSource])
}

/// Per-target, per-store, per-horizon, per-window forecast evaluation.
/// Written nightly by `ml/evaluation/evaluator.py` after reconciliation.
/// Reads are powered by `src/app/actions/forecasts/quality-actions.ts`
/// (to be added in Phase 1 Weeks 5–8) and chat tool `getForecastQuality`.
model MlForecastEvaluation {
  id                 String   @id @default(cuid())
  /// REVENUE / MENU_ITEM (daily) or BUSY_HOURS (hourly). Granularity is implicit.
  target             MlTarget
  storeId            String
  /// modelVersion of the forecasts being evaluated (matches Forecast*.modelVersion).
  modelVersion       String
  /// 0 = whole-day (revenue/menu_item). 0-23 = hour bucket (orders_hourly only).
  horizonDay         Int      @default(0)
  /// Inclusive evaluation window in business dates.
  windowStart        DateTime @db.Date
  windowEnd          DateTime @db.Date
  /// Aggregate accuracy metrics over the window.
  wape               Float?
  mape               Float?
  mae                Float?
  bias               Float?
  /// Empirical coverage of 80%/95% predictive intervals on this window.
  intervalCoverage80 Float?
  intervalCoverage95 Float?
  /// WAPE of the seasonal-naive (`y[t-7]`) baseline on the same rows.
  baselineWape       Float?
  /// WAPE of the enriched (weather+events) model variant if separately fit.
  enrichedWape       Float?
  /// Count of forecast rows whose actuals are not yet reconciled within the window.
  staleRowCount      Int      @default(0)
  /// Count of reconciled rows used for the metrics. Zero => row is informational only.
  sampleSize         Int      @default(0)
  /// When this evaluation row was written.
  computedAt         DateTime @default(now())

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([target, storeId, modelVersion, horizonDay, windowStart, windowEnd])
  @@index([storeId, target, computedAt(sort: Desc)])
  @@index([computedAt(sort: Desc)])
}

/// Phase 1 W6-8: middle level of the BottomUp reconciliation hierarchy.
/// Written nightly by `ml/reconciliation/category_aggregator.py` by aggregating
/// ForecastMenuItem.predictedQty × avgPrice per category.
model ForecastDailyCategory {
  id                   String    @id @default(cuid())
  storeId              String
  date                 DateTime  @db.Date
  categoryName         String
  revenue              Float
  reconciledRevenue    Float?
  reconciledAt         DateTime?
  reconciliationMethod String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, date, categoryName])
  @@index([storeId, date])
}

/// Phase 1 W6-8: one row per (store, date) capturing pre/post discrepancy
/// after the nightly hierarchical reconciliation. Powers the W11-12 quality
/// panel section 2 sparkline.
model MlReconciliationDaily {
  id                       String   @id @default(cuid())
  storeId                  String
  date                     DateTime @db.Date
  prePctDiscrepancyMedian  Float?
  prePctDiscrepancyP95     Float?
  postPctDiscrepancyMedian Float?
  postPctDiscrepancyP95    Float?
  methodUsed               String
  sampleSize               Int      @default(0)
  createdAt                DateTime @default(now())

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, date])
  @@index([storeId, date(sort: Desc)])
}

/// Phase 1 W11: per-day operator-gate verdicts. The W11-12 quality panel
/// section 4 reads from this table instead of JobRun.status — see plan
/// docs/superpowers/plans/2026-05-17-ml-phase1-w9-12-growth.md Task 12.
model OperatorGateDailyVerdict {
  id          String   @id @default(cuid())
  verdictDate DateTime @db.Date
  gateName    String
  passed      Boolean
  detail      String?
  computedAt  DateTime @default(now())

  @@unique([verdictDate, gateName])
}

/// One row per (store, day, opportunityType, title) produced by the
/// nightly growth pipeline (ml/growth/generators/*). Read-only feed —
/// no operator feedback capture in Phase 1. See spec §3.1.
model GrowthOpportunity {
  id                    String                @id @default(cuid())
  storeId               String
  asOfDate              DateTime              @db.Date
  opportunityType       OpportunityType
  title                 String
  estimatedDollarImpact Float
  confidence            OpportunityConfidence
  /// Array of { kind, ref, value } — see GrowthOpportunity.evidence type.
  evidence              Json                  @default("[]")
  caveats               String[]              @default([])
  suggestedAction       String
  createdAt             DateTime              @default(now())

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, asOfDate, opportunityType, title])
  @@index([storeId, asOfDate(sort: Desc)])
}

/// Store-hour weather features precomputed by offline Open-Meteo sync jobs.
/// Dashboard request paths must read these rows only; no weather provider calls.
model StoreWeatherSignal {
  id                          String   @id @default(cuid())
  storeId                     String
  date                        DateTime @db.Date
  hour                        Int
  temperatureC                Float?
  apparentTemperatureC        Float?
  precipitationMm             Float?
  precipitationProbabilityPct Float?
  windSpeedKph                Float?
  relativeHumidityPct         Float?
  weatherCode                 Int?
  provider                    String   @default("open-meteo")
  syncedAt                    DateTime @default(now()) @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, date, hour])
  @@index([storeId, date])
  @@index([syncedAt(sort: Desc)])
}

/// Store-day event-demand features precomputed by PredictHQ sync jobs.
/// Category counts are intentionally denormalized so ML and dashboards can
/// join one compact daily row without scanning raw provider payloads.
model StoreEventSignal {
  id                      String    @id @default(cuid())
  storeId                 String
  date                    DateTime  @db.Date
  radiusMiles             Float?
  hospitalityImpact       Float?
  hospitalitySpend        Float?
  attendance              Float?
  eventCount              Int       @default(0)
  sportsCount             Int       @default(0)
  concertsCount           Int       @default(0)
  festivalsCount          Int       @default(0)
  performingArtsCount     Int       @default(0)
  communityCount          Int       @default(0)
  conferencesCount        Int       @default(0)
  exposCount              Int       @default(0)
  topEventTitle           String?
  topEventCategory        String?
  topEventStartsAt        DateTime?
  topEventRank            Float?
  topEventLocalRank       Float?
  topEventAttendance      Float?
  topEventDistanceMiles   Float?
  majorEventCount         Int       @default(0)
  highLocalRankEventCount Int       @default(0)
  provider                String    @default("predicthq")
  raw                     Json?
  syncedAt                DateTime  @default(now()) @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, date])
  @@index([storeId, date])
  @@index([syncedAt(sort: Desc)])
}

/// Raw-ish top PredictHQ event rows retained for explanations and feature
/// engineering. The sync stores a bounded, location-scoped subset only.
model StoreEventDetailSignal {
  id              String    @id @default(cuid())
  storeId         String
  providerEventId String
  date            DateTime  @db.Date
  startsAt        DateTime?
  endsAt          DateTime?
  title           String?
  category        String?
  labels          Json?
  rank            Float?
  localRank       Float?
  attendance      Float?
  distanceMiles   Float?
  venueName       String?
  venueId         String?
  raw             Json?
  syncedAt        DateTime  @default(now()) @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, providerEventId])
  @@index([storeId, date])
  @@index([storeId, date, localRank(sort: Desc)])
  @@index([syncedAt(sort: Desc)])
}

/// Provider sync audit trail for weather/event backfills and rolling refreshes.
model ExternalSignalSyncRun {
  id          String    @id @default(cuid())
  provider    String
  storeId     String?
  startDate   DateTime? @db.Date
  endDate     DateTime? @db.Date
  status      String
  rowsWritten Int       @default(0)
  error       String?
  durationMs  Int?
  triggeredBy String
  startedAt   DateTime  @default(now())
  completedAt DateTime?

  store Store? @relation(fields: [storeId], references: [id], onDelete: SetNull)

  @@index([provider, startedAt(sort: Desc)])
  @@index([storeId, provider, startedAt(sort: Desc)])
  @@index([status, startedAt(sort: Desc)])
}

/// Anomaly events flagged by the nightly pipeline. Operators triage these
/// in a dedicated feed; an anomaly can be linked to an InventoryAdjustment
/// row when explained (e.g. "spike was a supplier return").
model AnomalyEvent {
  id             String        @id @default(cuid())
  storeId        String
  target         AnomalyTarget
  /// Free-form id within target — menu-item sku, ingredient id, etc. Null
  /// for store-wide signals like REVENUE.
  targetId       String?
  occurredOn     DateTime      @db.Date
  residual       Float
  zScore         Float?
  method         AnomalyMethod
  status         AnomalyStatus @default(OPEN)
  explanation    String?
  detectedAt     DateTime      @default(now())
  acknowledgedAt DateTime?

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId, occurredOn(sort: Desc)])
  @@index([status, detectedAt(sort: Desc)])
}

/// Per (store, otterItemSkuId) price elasticity — extracted nightly by an
/// OLS log(qty) ~ log(price) regression with weekday controls. `elasticity`
/// is the price coefficient: -1.0 = unit elastic; more negative = customers
/// drop off faster on price hikes; near 0 = inelastic (price changes don't
/// move volume). Positive values are noise; surface them as 'no_signal'
/// upstream.
model MenuItemElasticity {
  id              String   @id @default(cuid())
  storeId         String
  otterItemSkuId  String
  elasticity      Float
  intercept       Float
  /// R² goodness-of-fit on the training window. Below ~0.10 should be
  /// treated as low-confidence.
  fitR2           Float
  /// Number of daily observations used in the fit.
  sampleSize      Int
  /// Number of distinct price points observed. < 2 means no price variance
  /// — the row should be flagged as no_signal.
  pricePointCount Int
  meanPrice       Float
  meanQty         Float
  computedAt      DateTime @default(now())

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, otterItemSkuId])
  @@index([storeId, computedAt(sort: Desc)])
}

// ---------------------------------------------------------------------------
// Harri scheduling integration (LiveWire). Labor cost + clock-in/out alerts.
// Auth: AWS Cognito JWT (see docs/harri-api-notes.md). Sync runner:
// src/lib/harri-labor-sync.ts. All cost values stored as USD (already
// converted from Harri's native cents at write time).
// ---------------------------------------------------------------------------

model HarriBrand {
  id         String    @id @default(cuid())
  storeId    String
  brandId    Int       @unique // Harri operations brand id (one per physical store)
  brandName  String?
  active     Boolean   @default(true)
  lastSyncAt DateTime?
  createdAt  DateTime  @default(now())

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId])
}

model HarriDailyLabor {
  id           String   @id @default(cuid())
  storeId      String
  date         DateTime @db.Date
  actualCost   Float? // USD
  forecastCost Float? // USD
  categories   Json? // [{ id, code, name, total_labor_cost (USD) }]
  syncedAt     DateTime @default(now())

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, date])
  @@index([date])
  @@index([storeId, date])
}

// Per-day, per-position labor breakdown. One row per (storeId, date,
// categoryCode, positionCode). Source: /lpm-api/.../categories/positions/pay_types.
model HarriPositionDaily {
  id              String   @id @default(cuid())
  storeId         String
  date            DateTime @db.Date
  categoryCode    String // e.g. "QS", "MANAGE"
  categoryName    String?
  positionCode    String // e.g. "line-cook-5", "cashier", "operator"
  positionName    String?
  payType         String // "HOURLY" | "SALARIED"
  totalLabor      Float? // USD (sum of all cost amounts)
  netAmount       Float?
  overtimeAmount  Float?
  bonusAmount     Float?
  totalShiftCount Int?
  actualSeconds   Int?
  userIds         Int[] // Harri user ids who worked this position that day
  rawCost         Json? // full cost object preserved for forensics
  syncedAt        DateTime @default(now())

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, date, categoryCode, positionCode, payType])
  @@index([storeId, date])
}

model HarriTimekeepingAlert {
  id            String    @id @default(cuid())
  harriAlertId  BigInt    @unique // upsert key from API
  storeId       String
  date          DateTime  @db.Date
  employeeId    Int
  userId        Int
  positionId    Int?
  positionCode  String?
  positionName  String?
  categoryCode  String?
  alertTime     DateTime
  alertCode     String // EARLY_CLOCK_IN, LATE_CLOCK_OUT, MISSED_CLOCK_OUT_OT_NOW, ...
  alertTypeId   Int
  timeDiffSec   Int? // seconds early/late
  missedClockAt DateTime? // present on MISSED_* alerts
  syncedAt      DateTime  @default(now())

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId, date])
  @@index([userId, date])
}

// Directory cache for Harri team members. Refreshed on a monthly cron, never
// from the labor sync hot path. The (storeId, userId) unique key matches how
// alerts join — Harri's user_id is a global id but the same person can exist
// at multiple brands, so we scope by store.
model HarriEmployee {
  id         String   @id @default(cuid())
  storeId    String
  brandId    Int
  userId     Int
  employeeId Int?
  firstName  String?
  lastName   String?
  email      String?
  status     String?
  syncedAt   DateTime @default(now())

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, userId])
  @@index([storeId])
  @@index([userId])
}
