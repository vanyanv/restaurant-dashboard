generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  OWNER
}

enum Shift {
  MORNING
  EVENING
  BOTH
}

enum InvoiceStatus {
  PENDING
  MATCHED
  REVIEW
  APPROVED
  REJECTED
}

enum CogsStatus {
  COSTED
  UNMAPPED
  MISSING_COST
}

/// Which sub-route of the AI analytics surface this insight/run belongs to.
/// `OVERVIEW` is the landing page; `SALES`, `MENU`, `COGS`, `INVOICES` are the
/// four domain dropdowns.
enum AiAnalyticsRoute {
  OVERVIEW
  SALES
  MENU
  COGS
  INVOICES
}

/// `STORE` rows are pinned to a specific Store via `storeId`; `ALL` rows are
/// the network-wide rollup with `storeId = null`.
enum AiAnalyticsScope {
  STORE
  ALL
}

/// Lifecycle of a run. `OK` = generator + validator + critic all passed; the
/// `AiInsight` rows for this run are renderable. `PARTIAL` = some insights
/// were dropped by the critic but the run still produced output. `FAILED` =
/// validator rejected twice or the LLM call errored; the page renders a
/// "data unavailable" placeholder for the affected scope.
enum AiAnalyticsRunStatus {
  OK
  PARTIAL
  FAILED
}

/// Per-insight severity used for sorting and the "store of concern" callout.
/// Set by the critic during the validation pass.
enum AiInsightSeverity {
  INFO
  WATCH
  ALERT
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      Role
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Profile
  phone     String?
  avatarUrl String?
  timezone  String  @default("America/New_York")

  // Notification standing orders
  notifyInvoices     Boolean @default(true)
  notifyWeeklyReport Boolean @default(true)
  notifyAnomaly      Boolean @default(true)

  // Relations
  ownedStores          Store[]               @relation("StoreOwner")
  invoices             Invoice[]
  recipes              Recipe[]
  canonicalIngredients CanonicalIngredient[]
  ingredientSkuMatches IngredientSkuMatch[]

  @@index([email])
}

model Store {
  id        String   @id @default(cuid())
  name      String
  address   String?
  phone     String?
  ownerId   String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Yelp integration fields
  yelpBusinessId  String? // Yelp's unique business ID
  yelpRating      Float? // 1-5 star rating
  yelpReviewCount Int? // Total number of reviews
  yelpUrl         String? // Link to Yelp business page
  yelpUpdatedAt   DateTime? // Last time Yelp data was fetched
  yelpSearchTerm  String? // Store name + address used for search
  yelpLastSearch  DateTime? // Prevent excessive API calls

  // Fixed cost inputs for P&L (monthly figures; converted per period when displayed)
  fixedMonthlyLabor    Float?
  fixedMonthlyRent     Float?
  fixedMonthlyTowels   Float? // Towels/linen service; entered weekly in UI, stored as monthly equivalent
  fixedMonthlyCleaning Float? // Recurring deep-cleaning service

  // Platform commission rates (decimal, e.g. 0.21 = 21%). Applied to tpGrossSales on the P&L.
  uberCommissionRate     Float @default(0.21)
  doordashCommissionRate Float @default(0.25)

  // Per-store COGS target as a percent (e.g. 28.5 for 28.5%). Drives the
  // /dashboard/cogs target band and the "vs target" KPI. Nullable so existing
  // stores remain valid until set via the topbar chip.
  targetCogsPct Float?

  // Relations
  owner                User                  @relation("StoreOwner", fields: [ownerId], references: [id])
  prepTasks            PrepTask[]
  otterStores          OtterStore[]
  otterSummaries       OtterDailySummary[]
  otterMenuCategories  OtterMenuCategory[]
  otterMenuItems       OtterMenuItem[]
  otterRatings         OtterRating[]
  invoices             Invoice[]
  ingredientAliases    IngredientAlias[]
  otterItemMappings    OtterItemMapping[]
  otterSubItemMappings OtterSubItemMapping[]
  otterOrders          OtterOrder[]
  dailyCogsItems       DailyCogsItem[]
  aiInsights           AiInsight[]
  aiForecastRuns       AiForecastRun[]
  aiAnalyticsRuns      AiAnalyticsRun[]

  @@index([ownerId])
  @@index([yelpBusinessId])
}

model OtterStore {
  id           String    @id @default(cuid())
  storeId      String
  otterStoreId String    @unique
  lastSyncAt   DateTime?
  createdAt    DateTime  @default(now())

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)
}

model OtterDailySummary {
  id            String   @id @default(cuid())
  storeId       String
  date          DateTime @db.Date
  platform      String
  paymentMethod String

  // FP financials (first-party only)
  fpGrossSales     Float?
  fpNetSales       Float?
  fpDiscounts      Float?
  fpFees           Float?
  fpLostRevenue    Float?
  fpTaxCollected   Float?
  fpTaxRemitted    Float?
  fpTips           Float?
  fpServiceCharges Float?
  fpLoyalty        Float?

  // 3P financials (third-party only)
  tpGrossSales         Float?
  tpNetSales           Float?
  tpFees               Float?
  tpTaxCollected       Float?
  tpTaxRemitted        Float?
  tpDiscounts          Float?
  tpRefundsAdjustments Float?
  tpServiceCharges     Float?
  tpTipForRestaurant   Float?
  tpLoyaltyDiscount    Float?

  // Order counts
  fpOrderCount Int?
  tpOrderCount Int?

  // Till (FP cash rows only)
  tillPaidIn  Float?
  tillPaidOut Float?

  syncedAt DateTime @default(now()) @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, date, platform, paymentMethod])
  @@index([storeId])
  @@index([date])
}

model OtterMenuCategory {
  id       String   @id @default(cuid())
  storeId  String
  date     DateTime @db.Date
  category String

  fpQuantitySold       Float @default(0)
  fpTotalInclModifiers Float @default(0)
  fpTotalSales         Float @default(0)
  tpQuantitySold       Float @default(0)
  tpTotalInclModifiers Float @default(0)
  tpTotalSales         Float @default(0)

  syncedAt DateTime @default(now()) @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, date, category])
  @@index([storeId, date])
}

model OtterMenuItem {
  id       String   @id @default(cuid())
  storeId  String
  date     DateTime @db.Date
  category String
  itemName String

  isModifier Boolean @default(false)

  fpQuantitySold       Float @default(0)
  fpTotalInclModifiers Float @default(0)
  fpTotalSales         Float @default(0)
  tpQuantitySold       Float @default(0)
  tpTotalInclModifiers Float @default(0)
  tpTotalSales         Float @default(0)

  syncedAt DateTime @default(now()) @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, date, category, itemName, isModifier])
  @@index([storeId, date])
}

model OtterRating {
  id               String   @id @default(cuid())
  storeId          String
  externalReviewId String
  brandName        String
  facilityName     String
  storeName        String
  reviewedAt       DateTime
  platform         String
  reviewText       String?
  rating           Int
  externalOrderId  String?
  orderItemNames   String?
  syncedAt         DateTime @default(now()) @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, externalReviewId])
  @@index([storeId])
  @@index([reviewedAt])
  @@index([platform])
}

model PrepTask {
  id          String   @id @default(cuid())
  storeId     String
  taskName    String
  description String?
  shift       Shift
  isActive    Boolean  @default(true)
  orderIndex  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId])
}

model Invoice {
  id      String  @id @default(cuid())
  ownerId String
  storeId String?

  // Source tracking
  emailMessageId  String    @unique
  emailSubject    String?
  emailReceivedAt DateTime?
  attachmentName  String?

  // Extracted header
  vendorName      String
  invoiceNumber   String
  invoiceDate     DateTime? @db.Date
  dueDate         DateTime? @db.Date
  deliveryAddress String?

  // Totals
  subtotal    Float?
  taxAmount   Float?
  totalAmount Float

  // Matching
  status          InvoiceStatus @default(PENDING)
  matchConfidence Float?
  matchedAt       DateTime?

  // Gemini extraction metadata
  rawExtractionJson String?
  extractionModel   String?

  // PDF storage (Vercel Blob, access: 'private')
  pdfBlobPathname String?
  pdfBlobUrl      String?
  pdfSize         Int?
  pdfUploadedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  owner     User              @relation(fields: [ownerId], references: [id])
  store     Store?            @relation(fields: [storeId], references: [id], onDelete: SetNull)
  lineItems InvoiceLineItem[]

  @@index([ownerId])
  @@index([storeId])
  @@index([vendorName])
  @@index([invoiceDate])
  @@index([status])
  @@index([ownerId, createdAt])
  @@index([ownerId, vendorName, invoiceDate])
}

model InvoiceLineItem {
  id            String  @id @default(cuid())
  invoiceId     String
  lineNumber    Int
  sku           String?
  productName   String
  description   String?
  category      String?
  quantity      Float
  unit          String?
  packSize      Int?
  unitSize      Float?
  unitSizeUom   String?
  unitPrice     Float
  extendedPrice Float

  // Ingredient unification. Populated at sync time via (vendor, sku) match,
  // or at review-queue time by a manual confirm. Null = unmatched.
  canonicalIngredientId String?
  matchSource           String? // "sku" | "manual" | "alias"
  matchedAt             DateTime?

  invoice             Invoice              @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  canonicalIngredient CanonicalIngredient? @relation(fields: [canonicalIngredientId], references: [id], onDelete: SetNull)

  @@index([invoiceId])
  @@index([category])
  @@index([sku])
  @@index([canonicalIngredientId])
}

model InvoiceSyncLog {
  id              String    @id @default(cuid())
  startedAt       DateTime  @default(now())
  completedAt     DateTime?
  emailsScanned   Int       @default(0)
  invoicesCreated Int       @default(0)
  invoicesSkipped Int       @default(0)
  errors          Int       @default(0)
  errorDetails    String?
  triggeredBy     String
}

model Recipe {
  id               String   @id @default(cuid())
  ownerId          String
  itemName         String
  category         String
  servingSize      Float    @default(1)
  notes            String?
  foodCostOverride Float?
  isSellable       Boolean  @default(true)
  isAiGenerated    Boolean  @default(false)
  isConfirmed      Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  owner                User                  @relation(fields: [ownerId], references: [id])
  ingredients          RecipeIngredient[]
  usedInIngredients    RecipeIngredient[]    @relation("ComponentRecipe")
  otterItemMappings    OtterItemMapping[]
  otterSubItemMappings OtterSubItemMapping[]
  dailyCogsItems       DailyCogsItem[]

  @@unique([ownerId, itemName, category])
  @@index([ownerId])
}

/// A line in a recipe. Exactly one of `canonicalIngredientId` or `componentRecipeId`
/// must be set; this is enforced by a DB CHECK constraint in the migration.
model RecipeIngredient {
  id                    String   @id @default(cuid())
  recipeId              String
  canonicalIngredientId String?
  componentRecipeId     String?
  ingredientName        String?
  quantity              Float
  unit                  String
  notes                 String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  recipe              Recipe               @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  canonicalIngredient CanonicalIngredient? @relation(fields: [canonicalIngredientId], references: [id], onDelete: Restrict)
  componentRecipe     Recipe?              @relation("ComponentRecipe", fields: [componentRecipeId], references: [id], onDelete: Restrict)

  @@index([recipeId])
  @@index([canonicalIngredientId])
  @@index([componentRecipeId])
}

model CanonicalIngredient {
  id          String   @id @default(cuid())
  ownerId     String
  name        String
  defaultUnit String
  category    String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  /// How this ingredient is measured in recipes (lb, oz, each, tbsp, cup, gal, fl oz, g, ml, l).
  /// Null until set manually or hydrated from an invoice match.
  recipeUnit        String?
  /// Dollars per recipeUnit. Null when unknown.
  costPerRecipeUnit Float?
  /// "manual" — user-entered; "invoice" — auto-derived from latest matched line item.
  costSource        String?
  /// When true, invoice-match recomputes won't overwrite a manually set cost.
  costLocked        Boolean   @default(false)
  costUpdatedAt     DateTime?

  owner             User                 @relation(fields: [ownerId], references: [id])
  aliases           IngredientAlias[]
  recipeIngredients RecipeIngredient[]
  invoiceLineItems  InvoiceLineItem[]
  skuMatches        IngredientSkuMatch[]

  @@unique([ownerId, name])
  @@index([ownerId])
}

/// Learned (vendor, sku) → canonical ingredient matches. Future invoice line
/// items with the same (vendor, sku) auto-link to the canonical at sync time.
/// Manual matches from the review queue upsert here and backfill history.
model IngredientSkuMatch {
  id                    String   @id @default(cuid())
  ownerId               String
  vendorName            String
  sku                   String
  canonicalIngredientId String
  conversionFactor      Float    @default(1)
  fromUnit              String
  toUnit                String
  confirmedBy           String
  confirmedAt           DateTime @default(now())

  owner               User                @relation(fields: [ownerId], references: [id])
  canonicalIngredient CanonicalIngredient @relation(fields: [canonicalIngredientId], references: [id], onDelete: Cascade)

  @@unique([ownerId, vendorName, sku])
  @@index([canonicalIngredientId])
  @@index([ownerId])
}

model IngredientAlias {
  id                    String   @id @default(cuid())
  storeId               String
  canonicalIngredientId String?
  canonicalName         String
  rawName               String
  conversionFactor      Float    @default(1)
  fromUnit              String
  toUnit                String
  createdAt             DateTime @default(now())

  store               Store                @relation(fields: [storeId], references: [id], onDelete: Cascade)
  canonicalIngredient CanonicalIngredient? @relation(fields: [canonicalIngredientId], references: [id], onDelete: SetNull)

  @@unique([storeId, rawName])
  @@index([storeId, canonicalName])
  @@index([canonicalIngredientId])
}

model OtterItemMapping {
  id            String   @id @default(cuid())
  storeId       String
  otterItemName String
  /// Stable Otter sku (preferred for modern mappings). Legacy rows may leave this null.
  skuId         String?
  recipeId      String
  confirmedAt   DateTime @default(now())
  createdAt     DateTime @default(now())

  store  Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)
  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@unique([storeId, otterItemName])
  @@index([storeId])
  @@index([recipeId])
  @@index([skuId])
}

/// Per-(store, sub-item SKU) mapping of an Otter order modifier → a Recipe
/// that represents the modifier's ingredient usage (e.g. "Mod: Add Lettuce" →
/// 1 leaf). Multiple Otter sub-item SKUs with the same meaning (e.g.
/// "Add Pickle" vs "Add Pickles" with distinct Otter SKUs) can share one
/// recipe. Drives modifier cost in the daily COGS walker.
model OtterSubItemMapping {
  id               String   @id @default(cuid())
  storeId          String
  /// Stable Otter sub-item SKU — our primary key. Every OtterOrderSubItem has one.
  skuId            String
  /// Last seen display name for this SKU (for UI). Not used as identity.
  otterSubItemName String
  recipeId         String
  confirmedAt      DateTime @default(now())
  createdAt        DateTime @default(now())

  store  Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)
  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@unique([storeId, skuId])
  @@index([storeId])
  @@index([recipeId])
}

/// Per-(store, date, itemName) COGS row, materialized by
/// `src/lib/cogs-materializer.ts` so P&L reads don't walk recipes / invoices
/// at request time. Materialization is idempotent (upsert + per-day diff
/// cleanup) and runs on its own cron schedule independent of any sync or
/// mutation path. Rows only exist when we can actually cost the item as-of
/// `date`; UNMAPPED items and pre-cost-data dates are not materialized.
model DailyCogsItem {
  id           String     @id @default(cuid())
  storeId      String
  date         DateTime   @db.Date
  itemName     String
  category     String
  recipeId     String?
  qtySold      Float
  salesRevenue Float
  unitCost     Float?
  lineCost     Float      @default(0)
  status       CogsStatus
  /**
   * True when the recipe cost walk flagged at least one line as uncosted
   * (missing canonical cost or unit-conversion failure). `status` can still
   * be COSTED if other lines costed fine — `partialCost` says the total is
   * an understatement.
   */
  partialCost  Boolean    @default(false)
  computedAt   DateTime   @default(now())

  store  Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)
  recipe Recipe? @relation(fields: [recipeId], references: [id], onDelete: SetNull)

  @@unique([storeId, date, itemName, category])
  @@index([storeId, date])
  @@index([recipeId, date])
}

model OtterOrder {
  id                 String    @id @default(cuid())
  otterOrderId       String    @unique
  externalDisplayId  String?
  storeId            String
  otterStoreId       String
  platform           String
  referenceTimeLocal DateTime
  fulfillmentMode    String?
  orderStatus        String?
  acceptanceStatus   String?
  subtotal           Float     @default(0)
  tax                Float     @default(0)
  tip                Float     @default(0)
  commission         Float     @default(0)
  discount           Float     @default(0)
  total              Float     @default(0)
  customerName       String?
  detailsFetchedAt   DateTime?
  syncedAt           DateTime  @default(now()) @updatedAt

  store Store            @relation(fields: [storeId], references: [id], onDelete: Cascade)
  items OtterOrderItem[]

  @@index([storeId, referenceTimeLocal])
  @@index([detailsFetchedAt])
  @@index([platform])
}

model OtterOrderItem {
  id       String @id @default(cuid())
  orderId  String
  skuId    String
  name     String
  quantity Float
  price    Float  @default(0)

  order    OtterOrder          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  subItems OtterOrderSubItem[]

  @@index([orderId])
  @@index([skuId])
}

model OtterOrderSubItem {
  id          String  @id @default(cuid())
  orderItemId String
  skuId       String
  name        String
  quantity    Float
  price       Float   @default(0)
  subHeader   String?

  orderItem OtterOrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  @@index([orderItemId])
  @@index([skuId])
}

/// A single insight generated by the AI analytics pipeline. One row per insight
/// per (route, scope) cron run. Memory layer reads the trailing 14d of rows for
/// the same (route, storeId) into the next generator prompt so the model
/// escalates recurring issues and avoids repeating itself.
///
/// `storeId` is null when `scope = ALL` (the network rollup). The compound
/// index supports the page-load query path: "give me the latest insights for
/// this route and the user's selected store (or rollup)".
model AiInsight {
  id            String            @id @default(cuid())
  runId         String
  route         AiAnalyticsRoute
  scope         AiAnalyticsScope
  storeId       String?
  /// Short headline shown as the card title.
  headline      String
  /// Full prose body / recommendation. Already validated against source data
  /// and reviewed by the critic before being persisted.
  body          String
  severity      AiInsightSeverity @default(INFO)
  /// Estimated $ impact per period (for ranking and the materiality threshold
  /// applied by the critic). Null when the insight is qualitative.
  impactDollars Float?
  /// Compact JSON sidecar holding structured fields the page may render
  /// (e.g. line items, charts, comparison tables). Schema is route-specific.
  payload       Json?
  generatedAt   DateTime          @default(now())

  run   AiAnalyticsRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  store Store?         @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([route, scope, storeId, generatedAt])
  @@index([runId])
  @@index([storeId, generatedAt])
}

/// One row per AI demand/sales prediction. After the target window closes,
/// the daily reconciliation job writes back `actualValue` and `errorPct` so
/// the next forecast run can self-calibrate per (storeId, target).
///
/// `storeId` is required — forecasts are always store-scoped (ingredient
/// usage patterns differ across kitchens).
model AiForecastRun {
  id                String    @id @default(cuid())
  storeId           String
  /// Stable identifier for the thing being predicted (e.g. canonical
  /// ingredient name, menu item slug). The next-run prompt uses this to
  /// look up the most recent residual.
  target            String
  /// Predicted quantity for the target window, in `unit`.
  predictedValue    Float
  unit              String
  confidence        String? // "high" | "medium" | "low"
  /// Inclusive start / exclusive end of the window the prediction covers.
  targetWindowStart DateTime
  targetWindowEnd   DateTime
  /// Set by the reconciliation job after `targetWindowEnd` passes.
  actualValue       Float?
  errorPct          Float?
  reconciledAt      DateTime?
  generatedAt       DateTime  @default(now())

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId, target, generatedAt])
  @@index([targetWindowEnd, reconciledAt])
}

/// Audit log for every AI analytics cron invocation. Captures timing, status,
/// model identifiers, retry count from the validator, and any error so we can
/// debug failed runs and verify Groq budget usage.
model AiAnalyticsRun {
  id               String               @id @default(cuid())
  route            AiAnalyticsRoute
  scope            AiAnalyticsScope
  storeId          String?
  status           AiAnalyticsRunStatus
  /// Number of generator retries triggered by validator failures (0–1 in
  /// the steady-state pipeline; 2 means we wrote a placeholder).
  retryCount       Int                  @default(0)
  generatorModel   String?
  criticModel      String?
  promptTokens     Int?
  completionTokens Int?
  /// Number of insights persisted from this run (post-critic-pass).
  insightCount     Int                  @default(0)
  /// Number of insights the critic dropped for being unsupported, immaterial,
  /// or non-actionable.
  droppedByCritic  Int                  @default(0)
  errorDetails     String?
  startedAt        DateTime             @default(now())
  completedAt      DateTime?

  store    Store?      @relation(fields: [storeId], references: [id], onDelete: Cascade)
  insights AiInsight[]

  @@index([route, scope, storeId, startedAt])
  @@index([startedAt])
}
