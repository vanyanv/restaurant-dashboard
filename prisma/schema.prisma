generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  OWNER
}

enum Shift {
  MORNING
  EVENING
  BOTH
}

enum InvoiceStatus {
  PENDING
  MATCHED
  REVIEW
  APPROVED
  REJECTED
}

enum CogsStatus {
  COSTED
  UNMAPPED
  MISSING_COST
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String
  name          String
  role          Role
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Profile
  phone         String?
  avatarUrl     String?
  timezone      String    @default("America/New_York")

  // Notification standing orders
  notifyInvoices     Boolean @default(true)
  notifyWeeklyReport Boolean @default(true)
  notifyAnomaly      Boolean @default(true)

  // Relations
  ownedStores          Store[]   @relation("StoreOwner")
  invoices             Invoice[]
  recipes              Recipe[]
  canonicalIngredients CanonicalIngredient[]
  ingredientSkuMatches IngredientSkuMatch[]

  @@index([email])
}

model Store {
  id          String    @id @default(cuid())
  name        String
  address     String?
  phone       String?
  ownerId     String
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  // Yelp integration fields
  yelpBusinessId   String?   // Yelp's unique business ID
  yelpRating       Float?    // 1-5 star rating
  yelpReviewCount  Int?      // Total number of reviews
  yelpUrl          String?   // Link to Yelp business page
  yelpUpdatedAt    DateTime? // Last time Yelp data was fetched
  yelpSearchTerm   String?   // Store name + address used for search
  yelpLastSearch   DateTime? // Prevent excessive API calls

  // Fixed cost inputs for P&L (monthly figures; converted per period when displayed)
  fixedMonthlyLabor    Float?
  fixedMonthlyRent     Float?
  fixedMonthlyTowels   Float? // Towels/linen service; entered weekly in UI, stored as monthly equivalent
  fixedMonthlyCleaning Float? // Recurring deep-cleaning service

  // Platform commission rates (decimal, e.g. 0.21 = 21%). Applied to tpGrossSales on the P&L.
  uberCommissionRate     Float @default(0.21)
  doordashCommissionRate Float @default(0.25)
  
  // Relations
  owner           User      @relation("StoreOwner", fields: [ownerId], references: [id])
  prepTasks       PrepTask[]
  otterStores     OtterStore[]
  otterSummaries      OtterDailySummary[]
  otterMenuCategories OtterMenuCategory[]
  otterMenuItems      OtterMenuItem[]
  otterRatings        OtterRating[]
  invoices          Invoice[]
  ingredientAliases IngredientAlias[]
  otterItemMappings OtterItemMapping[]
  otterOrders       OtterOrder[]
  dailyCogsItems    DailyCogsItem[]

  @@index([ownerId])
  @@index([yelpBusinessId])
}

model OtterStore {
  id           String    @id @default(cuid())
  storeId      String
  otterStoreId String    @unique
  lastSyncAt   DateTime?
  createdAt    DateTime  @default(now())

  store        Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
}

model OtterDailySummary {
  id            String   @id @default(cuid())
  storeId       String
  date          DateTime @db.Date
  platform      String
  paymentMethod String

  // FP financials (first-party only)
  fpGrossSales     Float?
  fpNetSales       Float?
  fpDiscounts      Float?
  fpFees           Float?
  fpLostRevenue    Float?
  fpTaxCollected   Float?
  fpTaxRemitted    Float?
  fpTips           Float?
  fpServiceCharges Float?
  fpLoyalty        Float?

  // 3P financials (third-party only)
  tpGrossSales         Float?
  tpNetSales           Float?
  tpFees               Float?
  tpTaxCollected       Float?
  tpTaxRemitted        Float?
  tpDiscounts          Float?
  tpRefundsAdjustments Float?
  tpServiceCharges     Float?
  tpTipForRestaurant   Float?
  tpLoyaltyDiscount    Float?

  // Order counts
  fpOrderCount Int?
  tpOrderCount Int?

  // Till (FP cash rows only)
  tillPaidIn  Float?
  tillPaidOut Float?

  syncedAt DateTime @default(now()) @updatedAt

  store    Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, date, platform, paymentMethod])
  @@index([storeId])
  @@index([date])
}

model OtterMenuCategory {
  id        String   @id @default(cuid())
  storeId   String
  date      DateTime @db.Date
  category  String

  fpQuantitySold         Float @default(0)
  fpTotalInclModifiers   Float @default(0)
  fpTotalSales           Float @default(0)
  tpQuantitySold         Float @default(0)
  tpTotalInclModifiers   Float @default(0)
  tpTotalSales           Float @default(0)

  syncedAt DateTime @default(now()) @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, date, category])
  @@index([storeId])
  @@index([date])
}

model OtterMenuItem {
  id        String   @id @default(cuid())
  storeId   String
  date      DateTime @db.Date
  category  String
  itemName  String

  isModifier Boolean @default(false)

  fpQuantitySold         Float @default(0)
  fpTotalInclModifiers   Float @default(0)
  fpTotalSales           Float @default(0)
  tpQuantitySold         Float @default(0)
  tpTotalInclModifiers   Float @default(0)
  tpTotalSales           Float @default(0)

  syncedAt DateTime @default(now()) @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, date, category, itemName, isModifier])
  @@index([storeId])
  @@index([date])
}

model OtterRating {
  id               String   @id @default(cuid())
  storeId          String
  externalReviewId String
  brandName        String
  facilityName     String
  storeName        String
  reviewedAt       DateTime
  platform         String
  reviewText       String?
  rating           Int
  externalOrderId  String?
  orderItemNames   String?
  syncedAt         DateTime @default(now()) @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, externalReviewId])
  @@index([storeId])
  @@index([reviewedAt])
  @@index([platform])
}

model PrepTask {
  id          String    @id @default(cuid())
  storeId     String
  taskName    String
  description String?
  shift       Shift
  isActive    Boolean   @default(true)
  orderIndex  Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  // Relations
  store       Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId])
}

model Invoice {
  id              String        @id @default(cuid())
  ownerId         String
  storeId         String?

  // Source tracking
  emailMessageId  String        @unique
  emailSubject    String?
  emailReceivedAt DateTime?
  attachmentName  String?

  // Extracted header
  vendorName      String
  invoiceNumber   String
  invoiceDate     DateTime?     @db.Date
  dueDate         DateTime?     @db.Date
  deliveryAddress String?

  // Totals
  subtotal        Float?
  taxAmount       Float?
  totalAmount     Float

  // Matching
  status          InvoiceStatus @default(PENDING)
  matchConfidence Float?
  matchedAt       DateTime?

  // Gemini extraction metadata
  rawExtractionJson String?
  extractionModel   String?

  // PDF storage (Vercel Blob, access: 'private')
  pdfBlobPathname String?
  pdfBlobUrl      String?
  pdfSize         Int?
  pdfUploadedAt   DateTime?

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Relations
  owner           User          @relation(fields: [ownerId], references: [id])
  store           Store?        @relation(fields: [storeId], references: [id], onDelete: SetNull)
  lineItems       InvoiceLineItem[]

  @@index([ownerId])
  @@index([storeId])
  @@index([vendorName])
  @@index([invoiceDate])
  @@index([status])
}

model InvoiceLineItem {
  id            String   @id @default(cuid())
  invoiceId     String
  lineNumber    Int
  sku           String?
  productName   String
  description   String?
  category      String?
  quantity      Float
  unit          String?
  packSize      Int?
  unitSize      Float?
  unitSizeUom   String?
  unitPrice     Float
  extendedPrice Float

  // Ingredient unification. Populated at sync time via (vendor, sku) match,
  // or at review-queue time by a manual confirm. Null = unmatched.
  canonicalIngredientId String?
  matchSource           String?   // "sku" | "manual" | "alias"
  matchedAt             DateTime?

  invoice             Invoice              @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  canonicalIngredient CanonicalIngredient? @relation(fields: [canonicalIngredientId], references: [id], onDelete: SetNull)

  @@index([invoiceId])
  @@index([category])
  @@index([sku])
  @@index([canonicalIngredientId])
}

model InvoiceSyncLog {
  id              String    @id @default(cuid())
  startedAt       DateTime  @default(now())
  completedAt     DateTime?
  emailsScanned   Int       @default(0)
  invoicesCreated Int       @default(0)
  invoicesSkipped Int       @default(0)
  errors          Int       @default(0)
  errorDetails    String?
  triggeredBy     String
}

model Recipe {
  id                 String   @id @default(cuid())
  ownerId            String
  itemName           String
  category           String
  servingSize        Float    @default(1)
  notes              String?
  foodCostOverride   Float?
  isSellable         Boolean  @default(true)
  isAiGenerated      Boolean  @default(false)
  isConfirmed        Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  owner              User               @relation(fields: [ownerId], references: [id])
  ingredients        RecipeIngredient[]
  usedInIngredients  RecipeIngredient[] @relation("ComponentRecipe")
  otterItemMappings  OtterItemMapping[]
  dailyCogsItems     DailyCogsItem[]

  @@unique([ownerId, itemName, category])
  @@index([ownerId])
}

/// A line in a recipe. Exactly one of `canonicalIngredientId` or `componentRecipeId`
/// must be set; this is enforced by a DB CHECK constraint in the migration.
model RecipeIngredient {
  id                    String   @id @default(cuid())
  recipeId              String
  canonicalIngredientId String?
  componentRecipeId     String?
  ingredientName        String?
  quantity              Float
  unit                  String
  notes                 String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  recipe               Recipe               @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  canonicalIngredient  CanonicalIngredient? @relation(fields: [canonicalIngredientId], references: [id], onDelete: Restrict)
  componentRecipe      Recipe?              @relation("ComponentRecipe", fields: [componentRecipeId], references: [id], onDelete: Restrict)

  @@index([recipeId])
  @@index([canonicalIngredientId])
  @@index([componentRecipeId])
}

model CanonicalIngredient {
  id          String   @id @default(cuid())
  ownerId     String
  name        String
  defaultUnit String
  category    String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner              User                 @relation(fields: [ownerId], references: [id])
  aliases            IngredientAlias[]
  recipeIngredients  RecipeIngredient[]
  invoiceLineItems   InvoiceLineItem[]
  skuMatches         IngredientSkuMatch[]

  @@unique([ownerId, name])
  @@index([ownerId])
}

/// Learned (vendor, sku) → canonical ingredient matches. Future invoice line
/// items with the same (vendor, sku) auto-link to the canonical at sync time.
/// Manual matches from the review queue upsert here and backfill history.
model IngredientSkuMatch {
  id                    String   @id @default(cuid())
  ownerId               String
  vendorName            String
  sku                   String
  canonicalIngredientId String
  conversionFactor      Float    @default(1)
  fromUnit              String
  toUnit                String
  confirmedBy           String
  confirmedAt           DateTime @default(now())

  owner               User                @relation(fields: [ownerId], references: [id])
  canonicalIngredient CanonicalIngredient @relation(fields: [canonicalIngredientId], references: [id], onDelete: Cascade)

  @@unique([ownerId, vendorName, sku])
  @@index([canonicalIngredientId])
  @@index([ownerId])
}

model IngredientAlias {
  id                    String   @id @default(cuid())
  storeId               String
  canonicalIngredientId String?
  canonicalName         String
  rawName               String
  conversionFactor      Float    @default(1)
  fromUnit              String
  toUnit                String
  createdAt             DateTime @default(now())

  store                Store                @relation(fields: [storeId], references: [id], onDelete: Cascade)
  canonicalIngredient  CanonicalIngredient? @relation(fields: [canonicalIngredientId], references: [id], onDelete: SetNull)

  @@unique([storeId, rawName])
  @@index([storeId, canonicalName])
  @@index([canonicalIngredientId])
}

model OtterItemMapping {
  id            String   @id @default(cuid())
  storeId       String
  otterItemName String
  /// Stable Otter sku (preferred for modern mappings). Legacy rows may leave this null.
  skuId         String?
  recipeId      String
  confirmedAt   DateTime @default(now())
  createdAt     DateTime @default(now())

  store         Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  recipe        Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@unique([storeId, otterItemName])
  @@index([storeId])
  @@index([recipeId])
  @@index([skuId])
}

/// Per-(store, date, itemName) COGS row, materialized at write time so P&L reads
/// don't have to walk recipes/invoices at request time. Maintained by
/// `src/lib/cogs-materializer.ts` (fill) and `src/lib/cogs-invalidate.ts` (delete
/// on upstream mutation). Refill happens in the Otter sync route's COGS phase.
model DailyCogsItem {
  id           String     @id @default(cuid())
  storeId      String
  date         DateTime   @db.Date
  itemName     String
  category     String
  recipeId     String?
  qtySold      Float
  salesRevenue Float
  unitCost     Float?
  lineCost     Float      @default(0)
  status       CogsStatus
  computedAt   DateTime   @default(now())

  store  Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)
  recipe Recipe? @relation(fields: [recipeId], references: [id], onDelete: SetNull)

  @@unique([storeId, date, itemName, category])
  @@index([storeId, date])
  @@index([recipeId, date])
}

model OtterOrder {
  id                 String   @id @default(cuid())
  otterOrderId       String   @unique
  externalDisplayId  String?
  storeId            String
  otterStoreId       String
  platform           String
  referenceTimeLocal DateTime
  fulfillmentMode    String?
  orderStatus        String?
  acceptanceStatus   String?
  subtotal           Float    @default(0)
  tax                Float    @default(0)
  tip                Float    @default(0)
  commission         Float    @default(0)
  discount           Float    @default(0)
  total              Float    @default(0)
  customerName       String?
  detailsFetchedAt   DateTime?
  syncedAt           DateTime @default(now()) @updatedAt

  store Store             @relation(fields: [storeId], references: [id], onDelete: Cascade)
  items OtterOrderItem[]

  @@index([storeId, referenceTimeLocal])
  @@index([detailsFetchedAt])
  @@index([platform])
}

model OtterOrderItem {
  id        String @id @default(cuid())
  orderId   String
  skuId     String
  name      String
  quantity  Float
  price     Float  @default(0)

  order    OtterOrder         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  subItems OtterOrderSubItem[]

  @@index([orderId])
  @@index([skuId])
}

model OtterOrderSubItem {
  id          String  @id @default(cuid())
  orderItemId String
  skuId       String
  name        String
  quantity    Float
  price       Float   @default(0)
  subHeader   String?

  orderItem OtterOrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  @@index([orderItemId])
  @@index([skuId])
}