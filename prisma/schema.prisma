generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

enum Role {
  OWNER
}

enum Shift {
  MORNING
  EVENING
  BOTH
}

enum InvoiceStatus {
  PENDING
  MATCHED
  REVIEW
  APPROVED
  REJECTED
}

enum CogsStatus {
  COSTED
  UNMAPPED
  MISSING_COST
}

/// Tenant boundary for the dashboard. Every user, store, invoice, recipe,
/// etc. belongs to exactly one Account. Multiple users can share an account
/// (via the Invite flow) and see the same data. For now there is exactly
/// one Account row in production; the model is in place for future
/// multi-tenancy.
model Account {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users                         User[]
  stores                        Store[]
  invoices                      Invoice[]
  recipes                       Recipe[]
  canonicalIngredients          CanonicalIngredient[]
  ingredientSkuMatches          IngredientSkuMatch[]
  conversations                 Conversation[]
  invoiceLineEmbeddings         InvoiceLineEmbedding[]
  menuItemEmbeddings            MenuItemEmbedding[]
  recipeEmbeddings              RecipeEmbedding[]
  canonicalIngredientEmbeddings CanonicalIngredientEmbedding[]
  invites                       Invite[]
}

/// Single-use, time-limited signup token. An OWNER on an account creates
/// an Invite locally; the invitee opens /signup/{token}, signs up, and is
/// attached to the same accountId. The invite is marked consumed on
/// successful signup. Creation is gated to NODE_ENV !== "production" — the
/// dashboard should not expose invite generation in production. The
/// public consumption route is always live.
model Invite {
  id              String    @id @default(cuid())
  token           String    @unique
  accountId       String
  createdByUserId String
  expiresAt       DateTime
  usedAt          DateTime?
  usedByUserId    String?
  revokedAt       DateTime?
  createdAt       DateTime  @default(now())

  account   Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
  createdBy User    @relation("InvitesCreated", fields: [createdByUserId], references: [id])
  usedBy    User?   @relation("InvitesUsed", fields: [usedByUserId], references: [id])

  @@index([accountId])
  @@index([token])
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      Role
  accountId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Profile
  phone     String?
  avatarUrl String?
  timezone  String  @default("America/New_York")

  // Notification standing orders
  notifyInvoices     Boolean @default(true)
  notifyWeeklyReport Boolean @default(true)
  notifyAnomaly      Boolean @default(true)

  // Relations
  account              Account               @relation(fields: [accountId], references: [id])
  ownedStores          Store[]               @relation("StoreOwner")
  invoices             Invoice[]
  recipes              Recipe[]
  canonicalIngredients CanonicalIngredient[]
  ingredientSkuMatches IngredientSkuMatch[]
  conversations        Conversation[]
  invitesCreated       Invite[]              @relation("InvitesCreated")
  invitesUsed          Invite[]              @relation("InvitesUsed")

  @@index([email])
  @@index([accountId])
}

model Store {
  id        String   @id @default(cuid())
  name      String
  address   String?
  phone     String?
  ownerId   String
  accountId String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Yelp integration fields
  yelpBusinessId  String? // Yelp's unique business ID
  yelpRating      Float? // 1-5 star rating
  yelpReviewCount Int? // Total number of reviews
  yelpUrl         String? // Link to Yelp business page
  yelpUpdatedAt   DateTime? // Last time Yelp data was fetched
  yelpSearchTerm  String? // Store name + address used for search
  yelpLastSearch  DateTime? // Prevent excessive API calls

  // Fixed cost inputs for P&L (monthly figures; converted per period when displayed)
  fixedMonthlyLabor    Float?
  fixedMonthlyRent     Float?
  fixedMonthlyTowels   Float? // Towels/linen service; entered weekly in UI, stored as monthly equivalent
  fixedMonthlyCleaning Float? // Recurring deep-cleaning service

  // Platform commission rates (decimal, e.g. 0.21 = 21%). Applied to tpGrossSales on the P&L.
  uberCommissionRate     Float @default(0.21)
  doordashCommissionRate Float @default(0.25)

  // Per-store COGS target as a percent (e.g. 28.5 for 28.5%). Drives the
  // /dashboard/cogs target band and the "vs target" KPI. Nullable so existing
  // stores remain valid until set via the topbar chip.
  targetCogsPct Float?

  // Relations
  owner                User                  @relation("StoreOwner", fields: [ownerId], references: [id])
  account              Account               @relation(fields: [accountId], references: [id])
  prepTasks            PrepTask[]
  otterStores          OtterStore[]
  otterSummaries       OtterDailySummary[]
  otterHourlySummaries OtterHourlySummary[]
  otterMenuCategories  OtterMenuCategory[]
  otterMenuItems       OtterMenuItem[]
  otterRatings         OtterRating[]
  invoices             Invoice[]
  ingredientAliases    IngredientAlias[]
  otterItemMappings    OtterItemMapping[]
  otterSubItemMappings OtterSubItemMapping[]
  otterOrders          OtterOrder[]
  dailyCogsItems       DailyCogsItem[]
  aiForecastRuns       AiForecastRun[]

  @@index([ownerId])
  @@index([accountId])
  @@index([yelpBusinessId])
}

model OtterStore {
  id           String    @id @default(cuid())
  storeId      String
  otterStoreId String    @unique
  lastSyncAt   DateTime?
  createdAt    DateTime  @default(now())

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)
}

model OtterDailySummary {
  id            String   @id @default(cuid())
  storeId       String
  date          DateTime @db.Date
  platform      String
  paymentMethod String

  // FP financials (first-party only)
  fpGrossSales     Float?
  fpNetSales       Float?
  fpDiscounts      Float?
  fpFees           Float?
  fpLostRevenue    Float?
  fpTaxCollected   Float?
  fpTaxRemitted    Float?
  fpTips           Float?
  fpServiceCharges Float?
  fpLoyalty        Float?

  // 3P financials (third-party only)
  tpGrossSales         Float?
  tpNetSales           Float?
  tpFees               Float?
  tpTaxCollected       Float?
  tpTaxRemitted        Float?
  tpDiscounts          Float?
  tpRefundsAdjustments Float?
  tpServiceCharges     Float?
  tpTipForRestaurant   Float?
  tpLoyaltyDiscount    Float?

  // Order counts
  fpOrderCount Int?
  tpOrderCount Int?

  // Till (FP cash rows only)
  tillPaidIn  Float?
  tillPaidOut Float?

  syncedAt DateTime @default(now()) @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, date, platform, paymentMethod])
  @@index([storeId])
  @@index([date])
}

model OtterHourlySummary {
  id         String   @id @default(cuid())
  storeId    String
  date       DateTime @db.Date // LA calendar date
  hour       Int // 0–23, LA local hour
  orderCount Int      @default(0)
  netSales   Float    @default(0)
  updatedAt  DateTime @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, date, hour])
  @@index([date])
  @@index([storeId, date])
}

model OtterMenuCategory {
  id       String   @id @default(cuid())
  storeId  String
  date     DateTime @db.Date
  category String

  fpQuantitySold       Float @default(0)
  fpTotalInclModifiers Float @default(0)
  fpTotalSales         Float @default(0)
  tpQuantitySold       Float @default(0)
  tpTotalInclModifiers Float @default(0)
  tpTotalSales         Float @default(0)

  syncedAt DateTime @default(now()) @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, date, category])
  @@index([storeId, date])
}

model OtterMenuItem {
  id       String   @id @default(cuid())
  storeId  String
  date     DateTime @db.Date
  category String
  itemName String

  isModifier Boolean @default(false)

  fpQuantitySold       Float @default(0)
  fpTotalInclModifiers Float @default(0)
  fpTotalSales         Float @default(0)
  tpQuantitySold       Float @default(0)
  tpTotalInclModifiers Float @default(0)
  tpTotalSales         Float @default(0)

  syncedAt DateTime @default(now()) @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, date, category, itemName, isModifier])
  @@index([storeId, date])
}

model OtterRating {
  id               String   @id @default(cuid())
  storeId          String
  externalReviewId String
  brandName        String
  facilityName     String
  storeName        String
  reviewedAt       DateTime
  platform         String
  reviewText       String?
  rating           Int
  externalOrderId  String?
  orderItemNames   String?
  syncedAt         DateTime @default(now()) @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, externalReviewId])
  @@index([storeId])
  @@index([reviewedAt])
  @@index([platform])
}

model PrepTask {
  id          String   @id @default(cuid())
  storeId     String
  taskName    String
  description String?
  shift       Shift
  isActive    Boolean  @default(true)
  orderIndex  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId])
}

model Invoice {
  id        String  @id @default(cuid())
  ownerId   String
  accountId String
  storeId   String?

  // Source tracking
  emailMessageId  String    @unique
  emailSubject    String?
  emailReceivedAt DateTime?
  attachmentName  String?

  // Extracted header
  vendorName      String
  invoiceNumber   String
  invoiceDate     DateTime? @db.Date
  dueDate         DateTime? @db.Date
  deliveryAddress String?

  // Totals
  subtotal    Float?
  taxAmount   Float?
  totalAmount Float

  // Matching
  status          InvoiceStatus @default(PENDING)
  matchConfidence Float?
  matchedAt       DateTime?

  // Gemini extraction metadata
  rawExtractionJson String?
  extractionModel   String?

  // PDF storage (Vercel Blob, access: 'private')
  pdfBlobPathname String?
  pdfBlobUrl      String?
  pdfSize         Int?
  pdfUploadedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  owner     User              @relation(fields: [ownerId], references: [id])
  account   Account           @relation(fields: [accountId], references: [id])
  store     Store?            @relation(fields: [storeId], references: [id], onDelete: SetNull)
  lineItems InvoiceLineItem[]

  @@index([ownerId])
  @@index([accountId])
  @@index([storeId])
  @@index([vendorName])
  @@index([invoiceDate])
  @@index([status])
  @@index([ownerId, createdAt])
  @@index([accountId, createdAt])
  @@index([ownerId, vendorName, invoiceDate])
  @@index([accountId, vendorName, invoiceDate])
}

model InvoiceLineItem {
  id            String  @id @default(cuid())
  invoiceId     String
  lineNumber    Int
  sku           String?
  productName   String
  description   String?
  category      String?
  quantity      Float
  unit          String?
  packSize      Int?
  unitSize      Float?
  unitSizeUom   String?
  unitPrice     Float
  extendedPrice Float

  // Ingredient unification. Populated at sync time via (vendor, sku) match,
  // or at review-queue time by a manual confirm. Null = unmatched.
  canonicalIngredientId String?
  matchSource           String? // "sku" | "manual" | "alias"
  matchedAt             DateTime?

  invoice             Invoice              @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  canonicalIngredient CanonicalIngredient? @relation(fields: [canonicalIngredientId], references: [id], onDelete: SetNull)

  @@index([invoiceId])
  @@index([category])
  @@index([sku])
  @@index([canonicalIngredientId])
}

model InvoiceSyncLog {
  id              String    @id @default(cuid())
  startedAt       DateTime  @default(now())
  completedAt     DateTime?
  emailsScanned   Int       @default(0)
  invoicesCreated Int       @default(0)
  invoicesSkipped Int       @default(0)
  errors          Int       @default(0)
  errorDetails    String?
  triggeredBy     String
}

model Recipe {
  id               String   @id @default(cuid())
  ownerId          String
  accountId        String
  itemName         String
  category         String
  servingSize      Float    @default(1)
  notes            String?
  foodCostOverride Float?
  isSellable       Boolean  @default(true)
  isAiGenerated    Boolean  @default(false)
  isConfirmed      Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  owner                User                  @relation(fields: [ownerId], references: [id])
  account              Account               @relation(fields: [accountId], references: [id])
  ingredients          RecipeIngredient[]
  usedInIngredients    RecipeIngredient[]    @relation("ComponentRecipe")
  otterItemMappings    OtterItemMapping[]
  otterSubItemMappings OtterSubItemMapping[]
  dailyCogsItems       DailyCogsItem[]

  @@unique([ownerId, itemName, category])
  @@unique([accountId, itemName, category])
  @@index([ownerId])
  @@index([accountId])
}

/// A line in a recipe. Exactly one of `canonicalIngredientId` or `componentRecipeId`
/// must be set; this is enforced by a DB CHECK constraint in the migration.
model RecipeIngredient {
  id                    String   @id @default(cuid())
  recipeId              String
  canonicalIngredientId String?
  componentRecipeId     String?
  ingredientName        String?
  quantity              Float
  unit                  String
  notes                 String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  recipe              Recipe               @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  canonicalIngredient CanonicalIngredient? @relation(fields: [canonicalIngredientId], references: [id], onDelete: Restrict)
  componentRecipe     Recipe?              @relation("ComponentRecipe", fields: [componentRecipeId], references: [id], onDelete: Restrict)

  @@index([recipeId])
  @@index([canonicalIngredientId])
  @@index([componentRecipeId])
}

model CanonicalIngredient {
  id          String   @id @default(cuid())
  ownerId     String
  accountId   String
  name        String
  defaultUnit String
  category    String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  /// How this ingredient is measured in recipes (lb, oz, each, tbsp, cup, gal, fl oz, g, ml, l).
  /// Null until set manually or hydrated from an invoice match.
  recipeUnit        String?
  /// Dollars per recipeUnit. Null when unknown.
  costPerRecipeUnit Float?
  /// "manual" — user-entered; "invoice" — auto-derived from latest matched line item.
  costSource        String?
  /// When true, invoice-match recomputes won't overwrite a manually set cost.
  costLocked        Boolean   @default(false)
  costUpdatedAt     DateTime?

  owner             User                 @relation(fields: [ownerId], references: [id])
  account           Account              @relation(fields: [accountId], references: [id])
  aliases           IngredientAlias[]
  recipeIngredients RecipeIngredient[]
  invoiceLineItems  InvoiceLineItem[]
  skuMatches        IngredientSkuMatch[]

  @@unique([ownerId, name])
  @@unique([accountId, name])
  @@index([ownerId])
  @@index([accountId])
}

/// Learned (vendor, sku) → canonical ingredient matches. Future invoice line
/// items with the same (vendor, sku) auto-link to the canonical at sync time.
/// Manual matches from the review queue upsert here and backfill history.
model IngredientSkuMatch {
  id                    String   @id @default(cuid())
  ownerId               String
  accountId             String
  vendorName            String
  sku                   String
  canonicalIngredientId String
  conversionFactor      Float    @default(1)
  fromUnit              String
  toUnit                String
  confirmedBy           String
  confirmedAt           DateTime @default(now())

  owner               User                @relation(fields: [ownerId], references: [id])
  account             Account             @relation(fields: [accountId], references: [id])
  canonicalIngredient CanonicalIngredient @relation(fields: [canonicalIngredientId], references: [id], onDelete: Cascade)

  @@unique([ownerId, vendorName, sku])
  @@unique([accountId, vendorName, sku])
  @@index([canonicalIngredientId])
  @@index([ownerId])
  @@index([accountId])
}

model IngredientAlias {
  id                    String   @id @default(cuid())
  storeId               String
  canonicalIngredientId String?
  canonicalName         String
  rawName               String
  conversionFactor      Float    @default(1)
  fromUnit              String
  toUnit                String
  createdAt             DateTime @default(now())

  store               Store                @relation(fields: [storeId], references: [id], onDelete: Cascade)
  canonicalIngredient CanonicalIngredient? @relation(fields: [canonicalIngredientId], references: [id], onDelete: SetNull)

  @@unique([storeId, rawName])
  @@index([storeId, canonicalName])
  @@index([canonicalIngredientId])
}

model OtterItemMapping {
  id            String   @id @default(cuid())
  storeId       String
  otterItemName String
  /// Stable Otter sku (preferred for modern mappings). Legacy rows may leave this null.
  skuId         String?
  recipeId      String
  confirmedAt   DateTime @default(now())
  createdAt     DateTime @default(now())

  store  Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)
  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@unique([storeId, otterItemName])
  @@index([storeId])
  @@index([recipeId])
  @@index([skuId])
}

/// Per-(store, sub-item SKU) mapping of an Otter order modifier → a Recipe
/// that represents the modifier's ingredient usage (e.g. "Mod: Add Lettuce" →
/// 1 leaf). Multiple Otter sub-item SKUs with the same meaning (e.g.
/// "Add Pickle" vs "Add Pickles" with distinct Otter SKUs) can share one
/// recipe. Drives modifier cost in the daily COGS walker.
model OtterSubItemMapping {
  id               String   @id @default(cuid())
  storeId          String
  /// Stable Otter sub-item SKU — our primary key. Every OtterOrderSubItem has one.
  skuId            String
  /// Last seen display name for this SKU (for UI). Not used as identity.
  otterSubItemName String
  recipeId         String
  confirmedAt      DateTime @default(now())
  createdAt        DateTime @default(now())

  store  Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)
  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@unique([storeId, skuId])
  @@index([storeId])
  @@index([recipeId])
}

/// Per-(store, date, itemName) COGS row, materialized by
/// `src/lib/cogs-materializer.ts` so P&L reads don't walk recipes / invoices
/// at request time. Materialization is idempotent (upsert + per-day diff
/// cleanup) and runs on its own cron schedule independent of any sync or
/// mutation path. Rows only exist when we can actually cost the item as-of
/// `date`; UNMAPPED items and pre-cost-data dates are not materialized.
model DailyCogsItem {
  id           String     @id @default(cuid())
  storeId      String
  date         DateTime   @db.Date
  itemName     String
  category     String
  recipeId     String?
  qtySold      Float
  salesRevenue Float
  unitCost     Float?
  lineCost     Float      @default(0)
  status       CogsStatus
  /**
   * True when the recipe cost walk flagged at least one line as uncosted
   * (missing canonical cost or unit-conversion failure). `status` can still
   * be COSTED if other lines costed fine — `partialCost` says the total is
   * an understatement.
   */
  partialCost  Boolean    @default(false)
  computedAt   DateTime   @default(now())

  store  Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)
  recipe Recipe? @relation(fields: [recipeId], references: [id], onDelete: SetNull)

  @@unique([storeId, date, itemName, category])
  @@index([storeId, date])
  @@index([recipeId, date])
}

model OtterOrder {
  id                 String    @id @default(cuid())
  otterOrderId       String    @unique
  externalDisplayId  String?
  storeId            String
  otterStoreId       String
  platform           String
  referenceTimeLocal DateTime
  fulfillmentMode    String?
  orderStatus        String?
  acceptanceStatus   String?
  subtotal           Float     @default(0)
  tax                Float     @default(0)
  tip                Float     @default(0)
  commission         Float     @default(0)
  discount           Float     @default(0)
  total              Float     @default(0)
  customerName       String?
  detailsFetchedAt   DateTime?
  syncedAt           DateTime  @default(now()) @updatedAt

  store Store            @relation(fields: [storeId], references: [id], onDelete: Cascade)
  items OtterOrderItem[]

  @@index([storeId, referenceTimeLocal])
  @@index([detailsFetchedAt])
  @@index([platform])
}

model OtterOrderItem {
  id       String @id @default(cuid())
  orderId  String
  skuId    String
  name     String
  quantity Float
  price    Float  @default(0)

  order    OtterOrder          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  subItems OtterOrderSubItem[]

  @@index([orderId])
  @@index([skuId])
}

model OtterOrderSubItem {
  id          String  @id @default(cuid())
  orderItemId String
  skuId       String
  name        String
  quantity    Float
  price       Float   @default(0)
  subHeader   String?

  orderItem OtterOrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  @@index([orderItemId])
  @@index([skuId])
}

/// One row per AI demand/sales prediction. After the target window closes,
/// the daily reconciliation job writes back `actualValue` and `errorPct` so
/// the next forecast run can self-calibrate per (storeId, target).
///
/// `storeId` is required — forecasts are always store-scoped (ingredient
/// usage patterns differ across kitchens).
model AiForecastRun {
  id                String    @id @default(cuid())
  storeId           String
  /// Stable identifier for the thing being predicted (e.g. canonical
  /// ingredient name, menu item slug). The next-run prompt uses this to
  /// look up the most recent residual.
  target            String
  /// Predicted quantity for the target window, in `unit`.
  predictedValue    Float
  unit              String
  confidence        String? // "high" | "medium" | "low"
  /// Inclusive start / exclusive end of the window the prediction covers.
  targetWindowStart DateTime
  targetWindowEnd   DateTime
  /// Set by the reconciliation job after `targetWindowEnd` passes.
  actualValue       Float?
  errorPct          Float?
  reconciledAt      DateTime?
  generatedAt       DateTime  @default(now())

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId, target, generatedAt])
  @@index([targetWindowEnd, reconciledAt])
}

/// Owner-scoped chat thread. Each conversation is a sequence of `Message`
/// rows; the drawer and `/dashboard/chat` page share the same store so a
/// thread is portable across the two surfaces.
model Conversation {
  id        String    @id @default(cuid())
  ownerId   String
  accountId String
  owner     User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  account   Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  /// LLM-generated short title written after the first assistant turn. Null
  /// until then; the rail falls back to "Untitled".
  title     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  messages  Message[]

  @@index([ownerId, updatedAt])
  @@index([accountId, updatedAt])
}

/// One turn in a conversation. `role` is "user" | "assistant" | "tool".
/// Assistant turns may have one or more `ToolCall` children captured
/// alongside the streamed reply for the tool-trace expander.
model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String
  content        String
  toolCalls      ToolCall[]
  createdAt      DateTime     @default(now())

  @@index([conversationId, createdAt])
}

/// One tool invocation by the LLM during an assistant turn. `args` and
/// `result` are stored verbatim for the trace UI; `durationMs` is wall-clock
/// time of `execute()`.
model ToolCall {
  id         String   @id @default(cuid())
  messageId  String
  message    Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  toolName   String
  args       Json
  result     Json
  durationMs Int
  createdAt  DateTime @default(now())

  @@index([messageId])
}

/// pgvector embedding for one invoice line (or whole-invoice header when
/// `invoiceLineId` is null). `ownerId` is denormalized for fast `WHERE`
/// filtering during similarity search; we never trust the client.
/// `contentSnapshot` is the exact text that was embedded — used to skip
/// re-embedding unchanged rows.
model InvoiceLineEmbedding {
  id              String                      @id @default(cuid())
  invoiceId       String
  invoiceLineId   String?
  ownerId         String
  accountId       String
  contentSnapshot String
  embedding       Unsupported("vector(1536)")
  createdAt       DateTime                    @default(now())

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([ownerId])
  @@index([accountId])
  @@index([invoiceId])
}

/// pgvector embedding for one distinct Otter menu item (per
/// store + category + itemName tuple, modifiers excluded). The embedding
/// itself is keyed by a synthetic `menuItemId` (sha256 of the tuple,
/// truncated) so re-embeds overwrite prior rows. The tuple fields are
/// denormalized so `searchMenuItems` can return ready-to-display rows
/// without joining back to OtterMenuItem.
model MenuItemEmbedding {
  id              String                      @id @default(cuid())
  menuItemId      String                      @unique
  ownerId         String
  accountId       String
  storeId         String
  category        String
  itemName        String
  contentSnapshot String
  embedding       Unsupported("vector(1536)")
  createdAt       DateTime                    @default(now())

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([ownerId])
  @@index([accountId])
  @@index([storeId])
}

/// pgvector embedding for one owner-built Recipe. Chunk text folds in the
/// recipe's first few RecipeIngredient names so a query like "cheese
/// burger" can hit a recipe whose ingredients include cheddar even when
/// the recipe is just named "Smash Burger". `category` is denormalized so
/// `searchRecipes` can return ready-to-display rows without joining back.
model RecipeEmbedding {
  id              String                      @id @default(cuid())
  recipeId        String                      @unique
  ownerId         String
  accountId       String
  category        String
  itemName        String
  contentSnapshot String
  embedding       Unsupported("vector(1536)")
  createdAt       DateTime                    @default(now())

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([ownerId])
  @@index([accountId])
}

/// pgvector embedding for one owner CanonicalIngredient. Chunk text folds
/// in the per-store IngredientAlias `rawName`s so vendor jargon ("16/20
/// EZ peel", "EVOO") matches the canonical. `category` is denormalized so
/// `searchCanonicalIngredients` can return ready-to-display rows without
/// joining back.
model CanonicalIngredientEmbedding {
  id                    String                      @id @default(cuid())
  canonicalIngredientId String                      @unique
  ownerId               String
  accountId             String
  category              String?
  name                  String
  contentSnapshot       String
  embedding             Unsupported("vector(1536)")
  createdAt             DateTime                    @default(now())

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([ownerId])
  @@index([accountId])
}
