generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  OWNER
  MANAGER
}

enum Shift {
  MORNING
  EVENING
  BOTH
}

enum InvoiceStatus {
  PENDING
  MATCHED
  REVIEW
  APPROVED
  REJECTED
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String
  name          String
  role          Role
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  // Relations
  ownedStores   Store[]   @relation("StoreOwner")
  managedStores StoreManager[]
  reports       DailyReport[]
  invoices      Invoice[]

  @@index([email])
}

model Store {
  id          String    @id @default(cuid())
  name        String
  address     String?
  phone       String?
  ownerId     String
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  // Yelp integration fields
  yelpBusinessId   String?   // Yelp's unique business ID
  yelpRating       Float?    // 1-5 star rating
  yelpReviewCount  Int?      // Total number of reviews
  yelpUrl          String?   // Link to Yelp business page
  yelpUpdatedAt    DateTime? // Last time Yelp data was fetched
  yelpSearchTerm   String?   // Store name + address used for search
  yelpLastSearch   DateTime? // Prevent excessive API calls

  // Fixed cost inputs for P&L (monthly figures; converted per period when displayed)
  fixedMonthlyLabor Float?
  fixedMonthlyRent  Float?

  // Platform commission rates (decimal, e.g. 0.21 = 21%). Applied to tpGrossSales on the P&L.
  uberCommissionRate     Float @default(0.21)
  doordashCommissionRate Float @default(0.25)
  
  // Relations
  owner           User      @relation("StoreOwner", fields: [ownerId], references: [id])
  managers        StoreManager[]
  reports         DailyReport[]
  prepTasks       PrepTask[]
  otterStores     OtterStore[]
  otterSummaries      OtterDailySummary[]
  otterMenuCategories OtterMenuCategory[]
  otterMenuItems      OtterMenuItem[]
  otterRatings        OtterRating[]
  invoices        Invoice[]
  recipes          Recipe[]
  ingredientAliases IngredientAlias[]

  @@index([ownerId])
  @@index([yelpBusinessId])
}

model StoreManager {
  id          String    @id @default(cuid())
  storeId     String
  managerId   String
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  
  // Relations
  store       Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  manager     User      @relation(fields: [managerId], references: [id], onDelete: Cascade)
  
  @@unique([storeId, managerId])
  @@index([storeId])
  @@index([managerId])
}

model DailyReport {
  id                   String    @id @default(cuid())
  storeId              String
  date                 DateTime  @db.Date
  shift                Shift
  
  // Financial data
  startingAmount       Float
  endingAmount         Float
  totalSales           Float?
  cashSales            Float?
  cardSales            Float?
  tipCount             Float
  cashTips             Float?    // New field for cash tips
  
  // Prep completion
  morningPrepCompleted Int       // Percentage 0-100
  eveningPrepCompleted Int       // Percentage 0-100
  
  // Specific prep completion checkboxes
  prepMeat             Boolean   @default(false)
  prepSauce            Boolean   @default(false)
  prepOnionsSliced     Boolean   @default(false)
  prepOnionsDiced      Boolean   @default(false)
  prepTomatoesSliced   Boolean   @default(false)
  prepLettuce          Boolean   @default(false)
  
  // Additional info
  managerId            String
  notes                String?
  weatherCondition     String?
  customerCount        Int?
  
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  
  // Relations
  store                Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  manager              User      @relation(fields: [managerId], references: [id])
  prepTaskStatus       PrepTaskStatus[]
  
  @@unique([storeId, date, shift])
  @@index([storeId])
  @@index([date])
  @@index([managerId])
}

model OtterStore {
  id           String    @id @default(cuid())
  storeId      String
  otterStoreId String    @unique
  lastSyncAt   DateTime?
  createdAt    DateTime  @default(now())

  store        Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
}

model OtterDailySummary {
  id            String   @id @default(cuid())
  storeId       String
  date          DateTime @db.Date
  platform      String
  paymentMethod String

  // FP financials (first-party only)
  fpGrossSales     Float?
  fpNetSales       Float?
  fpDiscounts      Float?
  fpFees           Float?
  fpLostRevenue    Float?
  fpTaxCollected   Float?
  fpTaxRemitted    Float?
  fpTips           Float?
  fpServiceCharges Float?
  fpLoyalty        Float?

  // 3P financials (third-party only)
  tpGrossSales         Float?
  tpNetSales           Float?
  tpFees               Float?
  tpTaxCollected       Float?
  tpTaxRemitted        Float?
  tpDiscounts          Float?
  tpRefundsAdjustments Float?
  tpServiceCharges     Float?
  tpTipForRestaurant   Float?
  tpLoyaltyDiscount    Float?

  // Order counts
  fpOrderCount Int?
  tpOrderCount Int?

  // Till (FP cash rows only)
  tillPaidIn  Float?
  tillPaidOut Float?

  syncedAt DateTime @default(now()) @updatedAt

  store    Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, date, platform, paymentMethod])
  @@index([storeId])
  @@index([date])
}

model OtterMenuCategory {
  id        String   @id @default(cuid())
  storeId   String
  date      DateTime @db.Date
  category  String

  fpQuantitySold         Float @default(0)
  fpTotalInclModifiers   Float @default(0)
  fpTotalSales           Float @default(0)
  tpQuantitySold         Float @default(0)
  tpTotalInclModifiers   Float @default(0)
  tpTotalSales           Float @default(0)

  syncedAt DateTime @default(now()) @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, date, category])
  @@index([storeId])
  @@index([date])
}

model OtterMenuItem {
  id        String   @id @default(cuid())
  storeId   String
  date      DateTime @db.Date
  category  String
  itemName  String

  isModifier Boolean @default(false)

  fpQuantitySold         Float @default(0)
  fpTotalInclModifiers   Float @default(0)
  fpTotalSales           Float @default(0)
  tpQuantitySold         Float @default(0)
  tpTotalInclModifiers   Float @default(0)
  tpTotalSales           Float @default(0)

  syncedAt DateTime @default(now()) @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, date, category, itemName, isModifier])
  @@index([storeId])
  @@index([date])
}

model OtterRating {
  id               String   @id @default(cuid())
  storeId          String
  externalReviewId String
  brandName        String
  facilityName     String
  storeName        String
  reviewedAt       DateTime
  platform         String
  reviewText       String?
  rating           Int
  externalOrderId  String?
  orderItemNames   String?
  syncedAt         DateTime @default(now()) @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, externalReviewId])
  @@index([storeId])
  @@index([reviewedAt])
  @@index([platform])
}

model PrepTask {
  id          String    @id @default(cuid())
  storeId     String
  taskName    String
  description String?
  shift       Shift
  isActive    Boolean   @default(true)
  orderIndex  Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  // Relations
  store       Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  status      PrepTaskStatus[]
  
  @@index([storeId])
}

model PrepTaskStatus {
  id            String        @id @default(cuid())
  reportId      String
  taskId        String
  isCompleted   Boolean       @default(false)
  completedAt   DateTime?
  notes         String?

  // Relations
  report        DailyReport   @relation(fields: [reportId], references: [id], onDelete: Cascade)
  task          PrepTask      @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([reportId, taskId])
  @@index([reportId])
  @@index([taskId])
}

model Invoice {
  id              String        @id @default(cuid())
  ownerId         String
  storeId         String?

  // Source tracking
  emailMessageId  String        @unique
  emailSubject    String?
  emailReceivedAt DateTime?
  attachmentName  String?

  // Extracted header
  vendorName      String
  invoiceNumber   String
  invoiceDate     DateTime?     @db.Date
  dueDate         DateTime?     @db.Date
  deliveryAddress String?

  // Totals
  subtotal        Float?
  taxAmount       Float?
  totalAmount     Float

  // Matching
  status          InvoiceStatus @default(PENDING)
  matchConfidence Float?
  matchedAt       DateTime?

  // Gemini extraction metadata
  rawExtractionJson String?
  extractionModel   String?

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Relations
  owner           User          @relation(fields: [ownerId], references: [id])
  store           Store?        @relation(fields: [storeId], references: [id], onDelete: SetNull)
  lineItems       InvoiceLineItem[]

  @@index([ownerId])
  @@index([storeId])
  @@index([vendorName])
  @@index([invoiceDate])
  @@index([status])
}

model InvoiceLineItem {
  id            String   @id @default(cuid())
  invoiceId     String
  lineNumber    Int
  sku           String?
  productName   String
  description   String?
  category      String?
  quantity      Float
  unit          String?
  packSize      Int?
  unitSize      Float?
  unitSizeUom   String?
  unitPrice     Float
  extendedPrice Float

  invoice       Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@index([category])
  @@index([sku])
}

model InvoiceSyncLog {
  id              String    @id @default(cuid())
  startedAt       DateTime  @default(now())
  completedAt     DateTime?
  emailsScanned   Int       @default(0)
  invoicesCreated Int       @default(0)
  invoicesSkipped Int       @default(0)
  errors          Int       @default(0)
  errorDetails    String?
  triggeredBy     String
}

model Recipe {
  id            String   @id @default(cuid())
  storeId       String
  itemName      String
  category      String
  servingSize        Float    @default(1)
  notes              String?
  foodCostOverride   Float?
  isAiGenerated      Boolean  @default(false)
  isConfirmed   Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  store         Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  ingredients   RecipeIngredient[]

  @@unique([storeId, itemName, category])
  @@index([storeId])
}

model RecipeIngredient {
  id              String   @id @default(cuid())
  recipeId        String
  ingredientName  String
  quantity        Float
  unit            String
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  recipe          Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@index([recipeId])
}

model IngredientAlias {
  id                String   @id @default(cuid())
  storeId           String
  canonicalName     String
  rawName           String
  conversionFactor  Float    @default(1)
  fromUnit          String
  toUnit            String
  createdAt         DateTime @default(now())

  store             Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, rawName])
  @@index([storeId, canonicalName])
}